<section class="space-y-6">
  <section class="shell-card request-profile-table-card">
    <div class="request-profile-table-card__head">
      <div>
        <p class="request-profile-table-card__eyebrow"><%= t('system.eyebrow') %></p>
        <h1><%= t('system.users.title') %></h1>
        <p><%= t('system.users.description') %></p>
      </div>

      <div class="request-profile-table-card__actions">
        <a href="/system/users/new" class="btn-primary"><%= t('system.users.add') %></a>
      </div>
    </div>

    <div class="request-profile-table-scroll">
      <table class="request-profile-table">
        <thead>
          <tr>
            <th><%= t('field.fullName') %></th>
            <th><%= t('field.email') %></th>
            <th><%= t('portal.fields.phone') %></th>
            <th><%= t('dashboard.totalEvents') %></th>
            <th><%= t('system.users.records') %></th>
            <th><%= t('requestProfiles.table.status') %></th>
            <th><%= t('requestProfiles.table.actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach((user) => { %>
            <tr>
              <td><strong><%= user.full_name %></strong></td>
              <td><%= user.email %></td>
              <td><%= user.phone || t('common.notSet') %></td>
              <td><%= user.total_events %></td>
              <td><%= user.total_records %></td>
              <td><span class="status-<%= user.is_active ? 'active' : 'archived' %>"><%= user.is_active ? t('common.active') : t('common.inactive') %></span></td>
              <td>
                <div class="request-profile-actions">
                  <a href="/system/users/<%= user.id %>/edit" class="table-icon-button" title="<%= t('requestProfiles.editProfile') %>">
                    <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M13.85 2.85a1.8 1.8 0 0 1 2.55 2.55l-8.1 8.1-3.38.83.84-3.38zm1.42 1.13-1.7-1.7" /></svg>
                  </a>
                  <% if (currentUser.id !== user.id) { %>
                    <form action="/system/users/<%= user.id %>?_method=DELETE" method="POST" data-confirm-message="<%= t('common.confirmDelete') %>">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <button type="submit" class="table-icon-button" title="<%= t('system.users.delete') %>">
                        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 5h12M7 5V3.8A.8.8 0 0 1 7.8 3h4.4a.8.8 0 0 1 .8.8V5m-7 0v10.2a.8.8 0 0 0 .8.8h6.4a.8.8 0 0 0 .8-.8V5" /></svg>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</section>
