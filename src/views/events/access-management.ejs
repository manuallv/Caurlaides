<%
  const isPass = accessType === 'pass';
  const typeTitle = isPass ? t('nav.passes') : t('nav.wristbands');
  const typeLabel = isPass ? t('accessType.pass') : t('accessType.wristband');
  const routeBase = isPass ? 'passes' : 'wristbands';
  const sectionTitle = isPass ? t('event.sidebar.autoPasses') : t('event.sidebar.eventWristbands');
%>

<section class="space-y-6" data-access-admin-page>
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4" data-live-section="access-summary">
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('access.totalRequests') %></p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900" data-access-summary-total><%= requestSummary.totalRequests %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500">
        <%= isPass ? t('access.totalTypesPass') : t('access.totalTypesWristband') %>
      </p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900" data-access-summary-types><%= categories.length %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('access.pendingRequests') %></p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900" data-access-summary-pending><%= requestSummary.pendingRequests %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('access.handedOutRequests') %></p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900" data-access-summary-handed-out><%= requestSummary.handedOutRequests %></p>
    </div>
  </div>

  <div
    class="shell-card overflow-hidden access-admin-shell"
    data-live-section="access-workspace"
    data-access-workspace
    data-access-event-id="<%= activeEvent.id %>"
    data-access-page-type="<%= accessType %>"
    data-access-singular-label="<%= typeLabel %>"
    data-access-edit-label="<%= t('access.actions.editRequest') %>"
    data-access-not-set="<%= t('common.notSet') %>"
    data-access-status-pending-label="<%= t('statuses.pending') %>"
    data-access-status-handed-out-label="<%= t('statuses.handed_out') %>"
    data-access-filtered-count-template="<%= t('access.workspace.filteredCount', { count: '__COUNT__' }) %>"
    data-access-vehicle-plate-label="<%= t('access.fields.vehiclePlate') %>"
    data-access-entry-at-label="<%= t('access.entryAt') %>"
    data-access-create-action="/events/<%= activeEvent.id %>/<%= accessType %>/types"
    data-access-create-title="<%= t('access.types.editorCreate', { type: typeLabel }) %>"
    data-access-edit-title="<%= t('access.types.editorEdit', { type: typeLabel }) %>"
    data-access-create-submit="<%= t('access.addType', { type: typeLabel }) %>"
    data-access-save-submit="<%= t('access.saveType') %>"
    data-access-fullscreen-enter="<%= t('access.workspace.fullscreen') %>"
    data-access-fullscreen-exit="<%= t('access.workspace.exitFullscreen') %>"
    data-access-request-create-action="/events/<%= activeEvent.id %>/<%= accessType %>/requests"
    data-access-request-create-title="<%= t('access.modal.createTitle', { type: typeLabel }) %>"
    data-access-request-edit-title="<%= t('access.modal.editTitle', { type: typeLabel }) %>"
    data-access-request-create-submit="<%= t('access.actions.addRequest', { type: typeLabel }) %>"
    data-access-request-save-submit="<%= t('buttons.save') %>"
    data-access-history-title="<%= t('access.history.title') %>"
    data-access-history-loading="<%= t('access.history.loading') %>"
    data-access-history-empty="<%= t('access.history.empty') %>"
    data-access-history-error="<%= t('access.history.error') %>"
    data-access-history-gate-label="<%= t('access.history.gate') %>"
    data-access-history-source-label="<%= t('access.history.source') %>"
    data-access-history-button-label="<%= t('access.actions.viewHistory') %>"
    data-access-history-company-label="<%= t('check.resultCompany') %>"
    data-access-history-type-label="<%= t('check.resultType') %>"
    data-access-history-profile-label="<%= t('access.workspace.profile') %>"
    data-access-history-registered-label="<%= t('access.history.registeredAt') %>"
    data-access-history-entry-label="<%= t('access.entryAt') %>"
    data-access-history-last-entry-label="<%= t('access.history.lastEntryAt') %>"
    data-access-history-last-exit-label="<%= t('access.history.lastExitAt') %>"
  >
    <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <p class="worldnic-eyebrow"><%= sectionTitle %></p>
          <h1 class="mt-3 text-2xl font-bold text-slate-900"><%= t('access.requestTableTitle', { type: typeTitle }) %></h1>
          <p class="mt-2 text-sm text-slate-500"><%= t('access.workspace.description') %></p>
        </div>

        <div class="access-workspace-actions">
          <div class="access-workspace-tabs">
            <button type="button" class="access-workspace-tab is-active" data-access-view-tab="requests">
              <img src="/public/design-assets/icons/feather/grid.svg" alt="" />
              <span><%= t('access.views.requests', { type: typeTitle }) %></span>
            </button>
            <button type="button" class="access-workspace-tab" data-access-view-tab="types">
              <img src="/public/design-assets/icons/feather/edit-3.svg" alt="" />
              <span><%= t('access.views.types', { type: typeTitle }) %></span>
            </button>
          </div>

          <button type="button" class="btn-secondary" data-access-export-open>
            <img src="/public/design-assets/icons/feather/layers.svg" alt="" class="h-4 w-4 opacity-70" />
            <span><%= t('buttons.export') %></span>
          </button>
        </div>
      </div>
    </div>

    <div class="access-workspace-panel" data-access-view-panel="requests">
      <div class="access-workspace-toolbar">
        <form method="GET" action="/events/<%= activeEvent.id %>/<%= routeBase %>" class="access-filter-grid" data-live-filter-form>
          <input name="q" value="<%= filters.query %>" class="field-input" placeholder="<%= t('access.filters.search') %>" />

          <select name="profileId" class="field-input">
            <option value=""><%= t('access.filters.allProfiles') %></option>
            <% profiles.forEach((profile) => { %>
              <option value="<%= profile.id %>" <%= Number(filters.profileId) === Number(profile.id) ? 'selected' : '' %>><%= profile.name %></option>
            <% }) %>
          </select>

          <select name="categoryId" class="field-input">
            <option value=""><%= t('access.filters.allTypes') %></option>
            <% categories.forEach((category) => { %>
              <option value="<%= category.id %>" <%= Number(filters.categoryId) === Number(category.id) ? 'selected' : '' %>><%= category.name %></option>
            <% }) %>
          </select>

          <select name="status" class="field-input">
            <option value=""><%= t('access.filters.allStatuses') %></option>
            <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>><%= t('statuses.pending') %></option>
            <option value="handed_out" <%= filters.status === 'handed_out' ? 'selected' : '' %>><%= t('statuses.handed_out') %></option>
          </select>

          <select name="sort" class="field-input">
            <option value="newest" <%= filters.sort !== 'oldest' ? 'selected' : '' %>><%= t('access.filters.sortNewest') %></option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>><%= t('access.filters.sortOldest') %></option>
          </select>

          <input name="company" value="<%= filters.company %>" class="field-input" placeholder="<%= t('access.filters.company') %>" />

          <div class="access-filter-actions">
            <button type="button" class="btn-secondary" data-live-filter-reset data-filter-reset-url="/events/<%= activeEvent.id %>/<%= routeBase %>"><%= t('buttons.reset') %></button>
            <button type="button" class="btn-secondary access-fullscreen-toggle" data-access-fullscreen-toggle>
              <img src="/public/design-assets/icons/feather/layers.svg" alt="" class="h-4 w-4 opacity-70" />
              <span data-access-fullscreen-label><%= t('access.workspace.fullscreen') %></span>
            </button>
            <% if (canManage) { %>
              <button type="button" class="btn-primary" data-access-create-request>
                <%= t('access.actions.addRequest', { type: typeLabel }) %>
              </button>
            <% } %>
          </div>
        </form>
      </div>

      <div class="access-table-frame">
        <div class="access-table-frame__meta">
          <span class="toolbar-chip toolbar-chip-active" data-access-filtered-count-label><%= t('access.workspace.filteredCount', { count: requests.length }) %></span>
        </div>
        <div class="px-5 py-12 text-center sm:px-6 <%= requests.length ? 'hidden' : '' %>" data-access-empty-state>
          <p class="text-sm text-slate-500"><%= t('access.workspace.noRequests') %></p>
        </div>

        <div class="access-table-scroll <%= requests.length ? '' : 'hidden' %>" data-access-table-scroll>
          <table class="access-admin-table" data-access-requests-table>
            <thead>
              <tr>
                <th><%= t('access.workspace.person') %></th>
                <% if (isPass) { %>
                  <th><%= t('access.fields.vehiclePlate') %></th>
                <% } %>
                <th><%= t('access.fields.type') %></th>
                <th><%= t('access.workspace.profile') %></th>
                <th><%= t('access.workspace.contact') %></th>
                <th><%= t('access.workspace.status') %></th>
                <th><%= t('access.workspace.updated') %></th>
                <th><%= t('access.workspace.actions') %></th>
              </tr>
            </thead>
            <tbody data-access-requests-body>
              <% requests.forEach((request) => { %>
                <tr
                  data-request-row-id="<%= request.id %>"
                  data-request-status="<%= request.status %>"
                  data-request-created-ts="<%= new Date(request.created_at).getTime() || 0 %>"
                  data-request-category-id="<%= request.category_id %>"
                  data-request-profile-id="<%= request.request_profile_id || '' %>"
                  data-request-full-name="<%= request.full_name %>"
                  data-request-company-name="<%= request.company_name || '' %>"
                  data-request-phone="<%= request.phone || '' %>"
                  data-request-email="<%= request.email || '' %>"
                  data-request-vehicle-plate="<%= request.vehicle_plate || '' %>"
                  data-request-notes="<%= request.notes || '' %>"
                  data-request-profile-name="<%= request.profile_name || '' %>"
                  data-request-category-name="<%= request.category_name || '' %>"
                >
                    <td>
                      <div class="access-person-cell">
                        <div class="access-person-cell__title">
                          <img src="/public/design-assets/icons/feather/users.svg" alt="" />
                          <span><%= request.full_name %></span>
                        </div>
                        <% if (request.notes) { %>
                          <p class="access-person-cell__meta"><%= request.notes %></p>
                        <% } else if (request.email) { %>
                          <p class="access-person-cell__meta"><%= request.email %></p>
                        <% } else if (request.phone) { %>
                          <p class="access-person-cell__meta"><%= request.phone %></p>
                        <% } %>
                      </div>
                    </td>
                    <% if (isPass) { %>
                      <td>
                        <div class="access-data-stack">
                          <strong><%= request.vehicle_plate || t('common.notSet') %></strong>
                        </div>
                      </td>
                    <% } %>
                    <td>
                      <div class="access-data-stack">
                        <strong><%= request.category_name %></strong>
                        <span><%= typeLabel %></span>
                      </div>
                    </td>
                    <td>
                      <div class="access-data-stack">
                        <strong><%= request.company_name || t('common.notSet') %></strong>
                        <span><%= request.profile_name || t('common.notSet') %></span>
                      </div>
                    </td>
                    <td>
                      <div class="access-data-stack">
                        <strong><%= request.phone || t('common.notSet') %></strong>
                        <span><%= request.email || t('common.notSet') %></span>
                      </div>
                    </td>
                    <td>
                      <div class="access-data-stack">
                        <span
                          class="status-<%= request.status === 'handed_out' ? 'active' : 'pending' %>"
                          data-request-status-badge
                        ><%= t(`statuses.${request.status}`) %></span>
                        <% if (request.status_updated_at) { %>
                          <span class="access-status-time" data-request-status-time><%= helpers.formatDateTime(request.status_updated_at) %></span>
                        <% } else { %>
                          <span class="access-status-time" data-request-status-time>&nbsp;</span>
                        <% } %>
                      </div>
                    </td>
                    <td>
                      <div class="access-data-stack">
                        <strong data-request-updated-primary><%= helpers.formatDateTime(request.created_at) %></strong>
                        <% if (isPass && request.entered_at) { %>
                          <span data-request-updated-by><%= t('access.entryAt') %>: <%= helpers.formatDateTime(request.entered_at) %></span>
                        <% } else { %>
                          <span data-request-updated-by>&nbsp;</span>
                        <% } %>
                      </div>
                    </td>
                    <td>
                      <div class="access-row-actions">
                        <% if (isPass) { %>
                          <button
                            type="button"
                            class="table-icon-button"
                            data-access-history-open
                            data-request-id="<%= request.id %>"
                            data-request-history-url="/events/<%= activeEvent.id %>/pass/requests/<%= request.id %>/history"
                            data-request-full-name="<%= request.full_name %>"
                            data-request-vehicle-plate="<%= request.vehicle_plate || '' %>"
                            title="<%= t('access.actions.viewHistory') %>"
                            aria-label="<%= t('access.actions.viewHistory') %>"
                          >
                            <svg viewBox="0 0 20 20" aria-hidden="true">
                              <path d="M10 4.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11Z" />
                              <path d="M10 7v3l2 1.5" />
                            </svg>
                          </button>
                        <% } %>

                        <button
                          type="button"
                          class="table-icon-button"
                          data-access-edit-request
                          data-request-id="<%= request.id %>"
                          data-request-profile-id="<%= request.request_profile_id || '' %>"
                          data-request-category-id="<%= request.category_id %>"
                          data-request-full-name="<%= request.full_name %>"
                          data-request-company-name="<%= request.company_name || '' %>"
                          data-request-phone="<%= request.phone || '' %>"
                          data-request-email="<%= request.email || '' %>"
                          data-request-vehicle-plate="<%= request.vehicle_plate || '' %>"
                          data-request-notes="<%= request.notes || '' %>"
                          title="<%= t('access.actions.editRequest') %>"
                          aria-label="<%= t('access.actions.editRequest') %>"
                        >
                          <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 20h9" />
                            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5" />
                          </svg>
                        </button>

                        <form action="/events/<%= activeEvent.id %>/<%= accessType %>/requests/<%= request.id %>/status?_method=PUT" method="POST" class="access-status-form" data-live-form data-request-status-form>
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <% if (request.status === 'handed_out') { %>
                            <input type="hidden" name="status" value="pending" data-request-status-input />
                            <button type="submit" class="access-mini-button access-mini-button--secondary" data-request-status-button><%= t('statuses.pending') %></button>
                          <% } else { %>
                            <input type="hidden" name="status" value="handed_out" data-request-status-input />
                            <button type="submit" class="access-mini-button access-mini-button--primary" data-request-status-button><%= t('statuses.handed_out') %></button>
                          <% } %>
                        </form>
                      </div>
                    </td>
                  </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="access-table-footer">
          <span data-access-filtered-count-label><%= t('access.workspace.filteredCount', { count: requests.length }) %></span>
        </div>
      </div>

      <div class="portal-modal" data-access-history-modal>
        <button type="button" class="portal-modal__backdrop" data-access-history-close></button>
        <div class="portal-modal__dialog shell-card">
          <div class="portal-modal__header">
            <div class="portal-modal__title-block">
              <p class="worldnic-eyebrow" data-access-history-eyebrow><%= t('access.history.title') %></p>
              <h2 data-access-history-title><%= t('access.history.title') %></h2>
              <p class="mt-2 text-sm text-slate-500" data-access-history-meta></p>
            </div>

            <button type="button" class="table-icon-button" data-access-history-close aria-label="<%= t('buttons.cancel') %>">
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M5 5l10 10M15 5 5 15" />
              </svg>
            </button>
          </div>

          <div class="access-history-shell">
            <div class="access-history-summary" data-access-history-summary hidden></div>
            <p class="text-sm text-slate-500" data-access-history-loading><%= t('access.history.loading') %></p>
            <p class="text-sm text-slate-500" data-access-history-empty hidden><%= t('access.history.empty') %></p>
            <div class="access-history-list" data-access-history-list></div>
          </div>
        </div>
      </div>

      <div class="portal-modal" data-access-request-modal>
        <button type="button" class="portal-modal__backdrop" data-access-request-close></button>
        <div class="portal-modal__dialog portal-modal__dialog-wide shell-card">
          <div class="portal-modal__header">
            <div class="portal-modal__title-block">
              <p class="worldnic-eyebrow" data-access-request-modal-eyebrow><%= t('access.actions.editRequest') %></p>
              <h2 data-access-request-modal-title><%= t('access.modal.editTitle', { type: typeLabel }) %></h2>
            </div>

            <button type="button" class="table-icon-button" data-access-request-close aria-label="<%= t('buttons.cancel') %>">
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M5 5l10 10M15 5 5 15" />
              </svg>
            </button>
          </div>

          <form action="" method="POST" class="portal-modal__form" data-live-form data-access-request-form>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div data-access-request-method-holder>
              <input type="hidden" name="_method" value="PUT" />
            </div>

            <div class="portal-form-grid">
              <div>
                <label class="field-label"><%= t('access.fields.profileOptional') %></label>
                <select name="requestProfileId" class="field-input" data-access-request-profile>
                  <option value=""><%= t('access.filters.allProfiles') %></option>
                  <% profiles.forEach((profile) => { %>
                    <option value="<%= profile.id %>"><%= profile.name %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label class="field-label"><%= t('portal.selectType') %></label>
                <select name="categoryId" class="field-input" required data-access-request-category>
                  <% categories.forEach((category) => { %>
                    <option value="<%= category.id %>"><%= category.name %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label class="field-label"><%= t('portal.fields.fullName') %></label>
                <input name="fullName" type="text" class="field-input" required />
              </div>

              <div>
                <label class="field-label"><%= t('portal.fields.company') %></label>
                <input name="companyName" type="text" class="field-input" />
              </div>

              <div>
                <label class="field-label"><%= t('portal.fields.phone') %></label>
                <input name="phone" type="text" class="field-input" />
              </div>

              <div>
                <label class="field-label"><%= t('portal.fields.email') %></label>
                <input name="email" type="email" class="field-input" />
              </div>

              <% if (isPass) { %>
                <div>
                  <label class="field-label"><%= t('access.fields.vehiclePlate') %></label>
                  <input name="vehiclePlate" type="text" class="field-input" />
                </div>
              <% } %>

              <div class="portal-form-grid__full">
                <label class="field-label"><%= t('portal.fields.notes') %></label>
                <textarea name="notes" rows="4" class="field-input"></textarea>
              </div>
            </div>

            <div class="portal-modal__actions">
              <button type="button" class="btn-secondary" data-access-request-close><%= t('buttons.cancel') %></button>
              <button type="submit" class="btn-primary" data-access-request-submit-label><%= t('buttons.save') %></button>
            </div>
          </form>
        </div>
      </div>

      <div class="portal-modal" data-access-export-modal>
        <button type="button" class="portal-modal__backdrop" data-access-export-close></button>
        <div class="portal-modal__dialog shell-card">
          <div class="portal-modal__header">
            <div class="portal-modal__title-block">
              <p class="worldnic-eyebrow"><%= t('access.export.eyebrow') %></p>
              <h2><%= t('access.export.title') %></h2>
              <p class="mt-2 text-sm text-slate-500"><%= t('access.export.description') %></p>
            </div>
            <button type="button" class="table-icon-button" data-access-export-close aria-label="<%= t('buttons.cancel') %>">
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15" /></svg>
            </button>
          </div>

          <div class="access-export-grid">
            <a class="access-export-option" href="/events/<%= activeEvent.id %>/<%= accessType %>/export?format=xlsx">
              <strong><%= t('access.export.formats.xlsx') %></strong>
              <span><%= t('access.export.formats.xlsxDescription') %></span>
            </a>
            <a class="access-export-option" href="/events/<%= activeEvent.id %>/<%= accessType %>/export?format=csv">
              <strong><%= t('access.export.formats.csv') %></strong>
              <span><%= t('access.export.formats.csvDescription') %></span>
            </a>
            <a class="access-export-option" href="/events/<%= activeEvent.id %>/<%= accessType %>/export?format=pdf">
              <strong><%= t('access.export.formats.pdf') %></strong>
              <span><%= t('access.export.formats.pdfDescription') %></span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="access-workspace-panel is-hidden" data-access-view-panel="types">
      <div class="access-type-layout <%= canManage ? '' : 'access-type-layout--readonly' %>">
        <% if (canManage) { %>
          <div class="panel access-type-editor">
            <div class="flex flex-col gap-2">
              <p class="worldnic-eyebrow"><%= t('access.views.types', { type: typeTitle }) %></p>
              <h2 class="text-xl font-bold text-slate-900" data-access-type-form-title><%= t('access.types.editorCreate', { type: typeLabel }) %></h2>
              <p class="text-sm text-slate-500"><%= t('access.types.editorDescription') %></p>
            </div>

            <form action="/events/<%= activeEvent.id %>/<%= accessType %>/types" method="POST" class="mt-5 grid gap-4" data-live-form data-access-type-form>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div data-access-type-method-holder></div>

              <div>
                <label class="field-label"><%= t('access.typeName') %></label>
                <input name="name" type="text" class="field-input" required />
              </div>

              <div>
                <label class="field-label"><%= t('access.typeDescription') %></label>
                <textarea name="description" rows="4" class="field-input"></textarea>
              </div>

              <div class="grid gap-4 md:grid-cols-2">
                <div>
                  <label class="field-label"><%= t('access.referenceQuota') %></label>
                  <input name="quota" type="number" min="1" class="field-input" />
                </div>
                <div>
                  <label class="field-label"><%= t('access.sortOrder') %></label>
                  <input name="sortOrder" type="number" min="0" class="field-input" value="0" />
                </div>
              </div>

              <label class="flex items-center gap-3 rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700">
                <input type="checkbox" name="isActive" checked />
                <%= t('access.typeActive') %>
              </label>

              <div class="flex flex-wrap gap-2">
                <button type="submit" class="btn-primary"><span data-access-type-submit-label><%= t('access.addType', { type: typeLabel }) %></span></button>
                <button type="button" class="btn-secondary" data-access-type-reset><%= t('access.types.cancelEdit') %></button>
              </div>
            </form>
          </div>
        <% } %>

        <div class="panel access-type-list">
          <div class="flex flex-col gap-2">
            <h2 class="text-xl font-bold text-slate-900"><%= t('access.types.currentList', { type: typeTitle }) %></h2>
            <p class="text-sm text-slate-500"><%= t('access.types.currentListDescription') %></p>
          </div>

          <% if (!categories.length) { %>
            <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-6">
              <p class="text-sm text-slate-500"><%= t('access.noTypes', { type: typeTitle }) %></p>
            </div>
          <% } else { %>
            <div class="access-table-scroll mt-5">
              <table class="access-admin-table access-admin-table--types">
                <thead>
                  <tr>
                    <th><%= t('access.types.table.name') %></th>
                    <th><%= t('access.types.table.requests') %></th>
                    <th><%= t('access.types.table.quota') %></th>
                    <th><%= t('access.types.table.sort') %></th>
                    <th><%= t('access.types.table.status') %></th>
                    <th><%= t('access.types.table.actions') %></th>
                  </tr>
                </thead>
                <tbody>
                  <% categories.forEach((category) => { %>
                    <tr>
                      <td>
                        <div class="access-data-stack">
                          <strong><%= category.name %></strong>
                          <span><%= category.description || t('common.noDescription') %></span>
                        </div>
                      </td>
                      <td>
                        <div class="access-data-stack access-type-usage">
                          <strong>
                            <span data-access-type-total="<%= category.id %>" data-access-type-total-value="<%= category.total_requests || 0 %>"><%= category.total_requests || 0 %></span>
                            <span> <%= t('access.types.submittedCount') %></span>
                          </strong>
                          <span>
                            <span data-access-type-handed="<%= category.id %>" data-access-type-handed-value="<%= category.handed_out_requests || 0 %>"><%= category.handed_out_requests || 0 %></span>
                            <span> <%= t('access.types.handedOutCount') %></span>
                          </span>
                        </div>
                      </td>
                      <td><%= category.quota || '—' %></td>
                      <td><%= category.sort_order %></td>
                      <td>
                        <span class="status-<%= category.is_active ? 'active' : 'archived' %>"><%= category.is_active ? t('common.active') : t('common.inactive') %></span>
                      </td>
                      <td>
                        <div class="flex flex-wrap gap-2">
                          <% if (canManage) { %>
                            <button
                              type="button"
                              class="access-mini-button access-mini-button--secondary"
                              data-access-edit-type
                              data-type-id="<%= category.id %>"
                              data-type-name="<%= category.name %>"
                              data-type-description="<%= category.description || '' %>"
                              data-type-quota="<%= category.quota || '' %>"
                              data-type-sort-order="<%= category.sort_order %>"
                              data-type-is-active="<%= category.is_active ? '1' : '0' %>"
                            ><%= t('access.types.editButton') %></button>

                            <form action="/events/<%= activeEvent.id %>/<%= accessType %>/types/<%= category.id %>?_method=DELETE" method="POST" data-live-form data-confirm-message="<%= t('common.confirmDelete') %>">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <button type="submit" class="access-mini-button access-mini-button--danger"><%= t('access.deleteType') %></button>
                            </form>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
