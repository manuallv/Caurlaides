<section class="space-y-6">
  <div class="shell-card overflow-hidden">
    <div class="flex flex-col gap-4 border-b border-slate-200/80 px-5 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400"><%= t('dashboard.overview') %></p>
        <h1 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900"><%= t('dashboard.greeting', { name: currentUser.full_name.split(' ')[0] }) %></h1>
        <p class="mt-1 text-sm text-slate-500"><%= t('dashboard.description') %></p>
      </div>
      <a href="/events/new" class="btn-primary"><%= t('dashboard.createNewEvent') %></a>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('dashboard.totalEvents') %></p>
      <p class="mt-2 text-2xl font-extrabold text-slate-900"><%= totals.totalEvents %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('dashboard.totalPassRequests') %></p>
      <p class="mt-2 text-2xl font-extrabold text-slate-900"><%= totals.totalPassRequests %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('dashboard.totalWristbandRequests') %></p>
      <p class="mt-2 text-2xl font-extrabold text-slate-900"><%= totals.totalWristbandRequests %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('dashboard.totalRequests') %></p>
      <p class="mt-2 text-2xl font-extrabold text-slate-900"><%= totals.totalRequests %></p>
    </div>
  </div>

  <div class="shell-card overflow-hidden">
    <div class="flex flex-col gap-3 border-b border-slate-200/80 px-5 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-6">
      <div>
        <h1 class="text-2xl font-bold text-slate-900"><%= t('dashboard.yourEvents') %></h1>
        <p class="mt-1 text-sm text-slate-500"><%= t('dashboard.yourEventsDescription') %></p>
      </div>
      <a href="/events/new" class="btn-primary"><%= t('dashboard.createEvent') %></a>
    </div>

    <% if (!events.length) { %>
      <div class="px-5 py-12 text-center sm:px-6">
        <h2 class="text-xl font-bold text-slate-900"><%= t('dashboard.noEvents') %></h2>
        <p class="mt-2 text-sm text-slate-500"><%= t('dashboard.noEventsDescription') %></p>
      </div>
    <% } else { %>
      <div class="dashboard-event-grid px-5 py-5 sm:px-6">
        <% events.forEach((event, index) => {
          const isPinnedOpen = index === 0;
        %>
          <details
            class="panel dashboard-event-card"
            data-dashboard-event-card
            <%= isPinnedOpen ? 'open data-dashboard-event-pinned="true"' : '' %>
          >
            <summary class="dashboard-event-card__summary" data-dashboard-event-summary>
              <div class="dashboard-event-card__summary-copy">
                <div class="dashboard-event-card__summary-head">
                  <h2 class="dashboard-event-card__title"><%= event.name %></h2>
                  <span class="status-<%= event.status %>"><%= helpers.statusLabel(event.status) %></span>
                  <span class="dashboard-event-card__role"><%= helpers.roleLabel(event.role) %></span>
                </div>
                <div class="dashboard-event-card__summary-meta">
                  <p class="dashboard-event-card__summary-row">
                    <span><strong><%= t('dashboard.dates') %>:</strong> <%= helpers.formatDate(event.start_date) %> - <%= helpers.formatDate(event.end_date) %></span>
                    <span><strong><%= t('dashboard.location') %>:</strong> <%= event.location || '-' %></span>
                  </p>
                </div>
              </div>
              <span class="dashboard-event-card__summary-icon" aria-hidden="true">
                <svg viewBox="0 0 20 20">
                  <path d="m5.4 7.7 4.6 4.6 4.6-4.6 1.1 1.1-5.7 5.7-5.7-5.7z"></path>
                </svg>
              </span>
            </summary>

            <div class="dashboard-event-card__body">
              <p class="dashboard-event-card__description"><%= helpers.truncate(event.description || t('common.noDescription'), 150) %></p>

              <div class="dashboard-event-card__facts">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-400"><%= t('dashboard.dates') %></p>
                  <p class="mt-1 text-sm text-slate-700"><%= helpers.formatDate(event.start_date) %> - <%= helpers.formatDate(event.end_date) %></p>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-400"><%= t('dashboard.location') %></p>
                  <p class="mt-1 text-sm text-slate-700"><%= event.location || '-' %></p>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-400"><%= t('dashboard.collaborators') %></p>
                  <p class="mt-1 text-sm text-slate-700"><%= event.member_count %></p>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-400"><%= t('dashboard.passDeadline') %></p>
                  <p class="mt-1 text-sm text-slate-700"><%= helpers.formatDateTime(event.pass_request_deadline) %></p>
                </div>
              </div>

              <div class="dashboard-event-card__actions">
                <a href="/events/<%= event.id %>" class="btn-primary"><%= t('dashboard.openDashboard') %></a>
                <a href="/events/<%= event.id %>/wristbands" class="btn-secondary"><%= t('nav.wristbands') %></a>
                <a href="/events/<%= event.id %>/passes" class="btn-secondary"><%= t('nav.passes') %></a>
                <a href="/events/<%= event.id %>/members" class="btn-secondary"><%= t('event.collaborators') %></a>
              </div>
            </div>
          </details>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
