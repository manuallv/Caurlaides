<section class="mx-auto max-w-5xl">
  <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
    <div class="shell-card overflow-hidden">
      <div class="border-b border-slate-200/80 px-6 py-6 sm:px-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-700"><%= t('auth.portal') %></p>
        <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900">
          <%= t('auth.login.heroTitle') %>
        </h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
          <%= t('auth.login.heroDescription') %>
        </p>
      </div>
      <div class="grid gap-4 px-6 py-6 sm:grid-cols-3 sm:px-8">
        <div class="panel">
          <p class="text-sm font-semibold text-slate-900"><%= t('auth.login.panel.multiUser.title') %></p>
          <p class="mt-2 text-sm text-slate-500"><%= t('auth.login.panel.multiUser.body') %></p>
        </div>
        <div class="panel">
          <p class="text-sm font-semibold text-slate-900"><%= t('auth.login.panel.history.title') %></p>
          <p class="mt-2 text-sm text-slate-500"><%= t('auth.login.panel.history.body') %></p>
        </div>
        <div class="panel">
          <p class="text-sm font-semibold text-slate-900"><%= t('auth.login.panel.mobile.title') %></p>
          <p class="mt-2 text-sm text-slate-500"><%= t('auth.login.panel.mobile.body') %></p>
        </div>
      </div>
    </div>

    <div class="shell-card p-6 sm:p-8">
      <h2 class="text-2xl font-bold text-slate-900"><%= t('auth.login.title') %></h2>
      <p class="mt-2 text-sm text-slate-500"><%= t('auth.login.description') %></p>

      <form action="/login" method="POST" class="mt-6 space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div>
          <label for="email" class="field-label"><%= t('field.email') %></label>
          <input id="email" name="email" type="email" class="field-input" required />
        </div>

        <div>
          <label for="password" class="field-label"><%= t('field.password') %></label>
          <input id="password" name="password" type="password" class="field-input" required />
        </div>

        <button type="submit" class="btn-primary w-full"><%= t('auth.login.title') %></button>
      </form>

      <p class="mt-6 text-sm text-slate-500">
        <%= t('auth.login.needAccount') %>
        <a href="/register" class="font-semibold text-brand-700 hover:text-brand-800"><%= t('auth.login.createHere') %></a>
      </p>
    </div>
  </div>
</section>
