<%
  const submitAction = typeof checkAction === 'string' && checkAction ? checkAction : '/check';
  const eventPickerVisible = typeof showEventPicker === 'undefined' ? true : Boolean(showEventPicker);
  const publicVehicleCheckMode = Boolean(isPublicVehicleCheck);
  const hasCheckResult = Boolean(checkResult);
%>
<section
  class="mx-auto flex max-w-5xl flex-col gap-6"
  data-check-app
  data-check-result-hint="<%= t('check.resultHint') %>"
  data-check-recent-empty-label="<%= t('check.recentEmpty') %>"
  data-check-not-set="<%= t('common.notSet') %>"
>
  <% if (selectedEvent) { %>
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(300px,0.8fr)]">
      <div class="shell-card p-6 sm:p-8 check-form-card">
        <form action="<%= submitAction %>" method="POST" class="space-y-5" data-check-form>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <% if (!publicVehicleCheckMode) { %>
            <input type="hidden" name="eventId" value="<%= selectedEvent.id %>" />
          <% } %>

          <div>
            <label class="field-label"><%= t('check.vehiclePlate') %></label>
            <input
              name="vehiclePlate"
              type="text"
              class="field-input check-vehicle-input text-center text-2xl font-bold uppercase tracking-[0.22em]"
              placeholder="<%= t('check.vehiclePlatePlaceholder') %>"
              value="<%= checkFormValues?.vehiclePlate || '' %>"
              autocomplete="off"
              autocapitalize="characters"
              spellcheck="false"
              autofocus
              required
              data-check-vehicle-plate
            />
          </div>

          <div>
            <label class="field-label"><%= t('check.gateName') %></label>
            <input
              name="gateName"
              type="text"
              class="field-input"
              placeholder="<%= t('check.gateNamePlaceholder') %>"
              value="<%= checkFormValues?.gateName || '' %>"
              data-check-gate-name
            />
          </div>

          <div class="grid grid-cols-3 gap-3">
            <button
              type="submit"
              name="direction"
              value="check"
              class="btn-secondary py-4 text-sm font-semibold sm:text-base"
              data-check-submit-button
            >
              <%= t('check.checkButton') %>
            </button>
            <button
              type="submit"
              name="direction"
              value="entry"
              class="btn-primary py-4 text-sm font-semibold sm:text-base"
              data-check-submit-button
            >
              <%= t('check.entryButton') %>
            </button>
            <button
              type="submit"
              name="direction"
              value="exit"
              class="btn-secondary py-4 text-sm font-semibold sm:text-base"
              data-check-submit-button
            >
              <%= t('check.exitButton') %>
            </button>
          </div>

          <p class="check-inline-feedback hidden" data-check-feedback></p>
        </form>
      </div>

      <div class="flex flex-col gap-6">
        <div
          class="shell-card p-6 check-result-card<%= hasCheckResult ? ` is-${checkResult.direction === 'exit' ? 'exit' : checkResult.direction === 'check' ? 'check' : 'entry'}` : '' %>"
          data-check-result-card
        >
          <p class="worldnic-eyebrow"><%= t('check.resultTitle') %></p>

          <p class="mt-4 text-sm text-slate-500<%= hasCheckResult ? ' hidden' : '' %>" data-check-result-empty>
            <%= t('check.resultHint') %>
          </p>

          <div class="mt-4 space-y-4<%= hasCheckResult ? '' : ' hidden' %>" data-check-result-content>
            <div>
              <h2 class="text-xl font-extrabold text-slate-900" data-check-result-title>
                <%= hasCheckResult ? (checkResult.directionTitle || '') : '' %>
              </h2>
              <p class="mt-1 text-sm text-slate-500" data-check-result-plate><%= hasCheckResult ? ((checkResult.request?.vehiclePlate || checkResult.checkedPlate || '')) : '' %></p>
            </div>

            <div class="grid gap-3 text-sm text-slate-600">
              <div>
                <span class="font-semibold text-slate-900"><%= t('check.resultPerson') %>:</span>
                <span data-check-result-person><%= hasCheckResult ? (checkResult.request?.fullName || t('common.notSet')) : '' %></span>
              </div>
              <div>
                <span class="font-semibold text-slate-900"><%= t('check.resultCompany') %>:</span>
                <span data-check-result-company><%= hasCheckResult ? (checkResult.request?.companyName || t('common.notSet')) : '' %></span>
              </div>
              <div>
                <span class="font-semibold text-slate-900"><%= t('check.resultType') %>:</span>
                <span data-check-result-type><%= hasCheckResult ? (checkResult.request?.categoryName || t('common.notSet')) : '' %></span>
              </div>
              <div>
                <span class="font-semibold text-slate-900"><%= t('check.resultPresence') %>:</span>
                <span data-check-result-presence><%= hasCheckResult ? (checkResult.currentPresenceLabel || t('common.notSet')) : '' %></span>
              </div>
              <div>
                <span class="font-semibold text-slate-900"><%= t('check.resultPerformedAt') %>:</span>
                <span data-check-result-performed-at><%= hasCheckResult ? (checkResult.performedAtLabel || t('common.notSet')) : '' %></span>
              </div>
            </div>

            <div
              class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900<%= hasCheckResult && checkResult.alreadyEnteredMessage ? '' : ' hidden' %>"
              data-check-result-note
            >
              <%= hasCheckResult ? (checkResult.alreadyEnteredMessage || '') : '' %>
            </div>
          </div>
        </div>

        <div class="shell-card p-6">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="worldnic-eyebrow"><%= selectedEvent.name %></p>
              <h2 class="mt-2 text-xl font-bold text-slate-900"><%= t('check.recentTitle') %></h2>
            </div>
          </div>

          <p class="mt-4 text-sm text-slate-500<%= recentMovements.length ? ' hidden' : '' %>" data-check-recent-empty>
            <%= t('check.recentEmpty') %>
          </p>

          <div class="mt-4 space-y-3<%= recentMovements.length ? '' : ' hidden' %>" data-check-recent-list>
            <% recentMovements.forEach((movement) => { %>
              <div class="rounded-2xl border border-slate-200 px-4 py-3">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-sm font-semibold text-slate-900"><%= movement.vehicle_plate %> · <%= movement.full_name %></p>
                    <p class="mt-1 text-xs text-slate-500">
                      <%= t('check.recentMeta', {
                        direction: t(movement.direction === 'exit' ? 'check.direction.exit' : 'check.direction.entry'),
                        time: helpers.formatDateTime(movement.created_at),
                      }) %>
                    </p>
                    <% if (movement.company_name || movement.category_name || movement.gate_name) { %>
                      <p class="mt-2 text-xs text-slate-500">
                        <%= [movement.company_name, movement.category_name, movement.gate_name].filter(Boolean).join(' · ') %>
                      </p>
                    <% } %>
                  </div>

                  <span class="portal-type-pill <%= movement.direction === 'exit' ? 'is-wristband' : 'is-pass' %>">
                    <%= t(movement.direction === 'exit' ? 'check.direction.exit' : 'check.direction.entry') %>
                  </span>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</section>
