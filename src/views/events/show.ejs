<section class="space-y-6">
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500">Pass requests</p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900"><%= summary.totalPassRequests %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500">Wristband requests</p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900"><%= summary.totalWristbandRequests %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500">Pass categories</p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900"><%= summary.totalPassCategories %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500">Wristband categories</p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900"><%= summary.totalWristbandCategories %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500">Collaborators</p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900"><%= summary.totalMembers %></p>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
    <div class="space-y-6">
      <div class="shell-card overflow-hidden">
        <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
          <h2 class="text-xl font-bold text-slate-900">Operational summary</h2>
          <p class="mt-1 text-sm text-slate-500">This dashboard is ready for live counters once request tables are in active use.</p>
        </div>
        <div class="grid gap-4 px-5 py-5 sm:px-6 md:grid-cols-2">
          <div class="panel">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Pass deadline</p>
            <p class="mt-2 text-sm font-semibold text-slate-900"><%= helpers.formatDateTime(activeEvent.pass_request_deadline) %></p>
          </div>
          <div class="panel">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Wristband deadline</p>
            <p class="mt-2 text-sm font-semibold text-slate-900"><%= helpers.formatDateTime(activeEvent.wristband_request_deadline) %></p>
          </div>
          <div class="panel md:col-span-2">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Description</p>
            <p class="mt-2 text-sm leading-6 text-slate-600"><%= activeEvent.description || 'No description added yet.' %></p>
          </div>
        </div>
      </div>

      <div class="shell-card overflow-hidden">
        <div class="flex items-center justify-between border-b border-slate-200/80 px-5 py-5 sm:px-6">
          <div>
            <h2 class="text-xl font-bold text-slate-900">Recent activity</h2>
            <p class="mt-1 text-sm text-slate-500">Every important event change is written to the audit trail.</p>
          </div>
          <a href="/events/<%= activeEvent.id %>/activity" class="btn-secondary">Open full log</a>
        </div>
        <div class="px-5 py-5 sm:px-6">
          <% if (!recentActivity.length) { %>
            <p class="text-sm text-slate-500">No activity recorded yet.</p>
          <% } else { %>
            <div class="space-y-4">
              <% recentActivity.forEach((entry) => { %>
                <div class="border-l-2 border-brand-200 pl-4">
                  <p class="text-sm font-semibold text-slate-900"><%= entry.message %></p>
                  <p class="mt-1 text-xs uppercase tracking-wide text-slate-400">
                    <%= entry.actor_name || 'System' %> · <%= helpers.formatDateTime(entry.created_at) %>
                  </p>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="shell-card overflow-hidden">
        <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
          <h2 class="text-xl font-bold text-slate-900">Team snapshot</h2>
        </div>
        <div class="space-y-3 px-5 py-5 sm:px-6">
          <% members.slice(0, 5).forEach((member) => { %>
            <div class="flex items-center justify-between rounded-2xl border border-slate-200 px-4 py-3">
              <div>
                <p class="text-sm font-semibold text-slate-900"><%= member.full_name %></p>
                <p class="text-xs text-slate-500"><%= member.email %></p>
              </div>
              <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600"><%= member.role %></span>
            </div>
          <% }) %>
          <a href="/events/<%= activeEvent.id %>/members" class="btn-secondary w-full">Manage collaborators</a>
        </div>
      </div>

      <div class="shell-card overflow-hidden">
        <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
          <h2 class="text-xl font-bold text-slate-900">Quick actions</h2>
        </div>
        <div class="grid gap-3 px-5 py-5 sm:px-6">
          <a href="/events/<%= activeEvent.id %>/categories" class="btn-primary">Manage categories</a>
          <% if (canManage) { %>
            <a href="/events/<%= activeEvent.id %>/edit" class="btn-secondary">Edit event settings</a>
          <% } %>
          <a href="/events/<%= activeEvent.id %>/activity" class="btn-secondary">View audit history</a>
        </div>
      </div>
    </div>
  </div>
</section>
