<%
  const isPass = accessType === 'pass';
  const typeTitle = isPass ? t('nav.passes') : t('nav.wristbands');
  const typeLabel = isPass ? t('accessType.pass') : t('accessType.wristband');
  const routeBase = isPass ? 'passes' : 'wristbands';
%>

<section class="space-y-6">
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4" data-live-section="access-summary">
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('access.totalRequests') %></p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900"><%= requestSummary.totalRequests %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('access.totalTypes') %></p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900"><%= categories.length %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('access.pendingRequests') %></p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900"><%= requestSummary.pendingRequests %></p>
    </div>
    <div class="metric-card">
      <p class="text-sm font-medium text-slate-500"><%= t('access.handedOutRequests') %></p>
      <p class="mt-3 text-3xl font-extrabold text-slate-900"><%= requestSummary.handedOutRequests %></p>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <div class="space-y-6">
      <div class="shell-card overflow-hidden">
        <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
          <h2 class="text-xl font-bold text-slate-900"><%= t('access.availableTypes', { type: typeTitle }) %></h2>
          <p class="mt-1 text-sm text-slate-500"><%= t('access.availableTypesDescription', { type: typeLabel }) %></p>
        </div>

        <% if (canManage) { %>
          <form action="/events/<%= activeEvent.id %>/<%= accessType %>/types" method="POST" class="space-y-4 border-b border-slate-200/80 px-5 py-5 sm:px-6">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div>
              <label class="field-label" for="<%= accessType %>-type-name"><%= t('access.typeName') %></label>
              <input id="<%= accessType %>-type-name" name="name" type="text" class="field-input" required />
            </div>
            <div>
              <label class="field-label" for="<%= accessType %>-type-description"><%= t('access.typeDescription') %></label>
              <textarea id="<%= accessType %>-type-description" name="description" rows="3" class="field-input"></textarea>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label class="field-label" for="<%= accessType %>-type-quota"><%= t('access.referenceQuota') %></label>
                <input id="<%= accessType %>-type-quota" name="quota" type="number" min="1" class="field-input" />
              </div>
              <div>
                <label class="field-label" for="<%= accessType %>-type-sort-order"><%= t('access.sortOrder') %></label>
                <input id="<%= accessType %>-type-sort-order" name="sortOrder" type="number" min="0" class="field-input" value="0" />
              </div>
            </div>
            <label class="flex items-center gap-3 rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700">
              <input type="checkbox" name="isActive" checked />
              <%= t('access.typeActive') %>
            </label>
            <button type="submit" class="btn-primary w-full"><%= t('access.addType', { type: typeLabel }) %></button>
          </form>
        <% } %>

        <div class="space-y-4 px-5 py-5 sm:px-6">
          <% if (!categories.length) { %>
            <p class="text-sm text-slate-500"><%= t('access.noTypes', { type: typeTitle }) %></p>
          <% } %>

          <% categories.forEach((category) => { %>
            <form action="/events/<%= activeEvent.id %>/<%= accessType %>/types/<%= category.id %>?_method=PUT" method="POST" class="rounded-2xl border border-slate-200 p-4">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="grid gap-4">
                <div class="grid gap-4 md:grid-cols-2">
                  <div>
                    <label class="field-label"><%= t('access.typeName') %></label>
                    <input name="name" type="text" class="field-input" value="<%= category.name %>" <%= canManage ? '' : 'disabled' %> />
                  </div>
                  <div>
                    <label class="field-label"><%= t('access.referenceQuota') %></label>
                    <input name="quota" type="number" min="1" class="field-input" value="<%= category.quota || '' %>" <%= canManage ? '' : 'disabled' %> />
                  </div>
                </div>
                <div>
                  <label class="field-label"><%= t('access.typeDescription') %></label>
                  <textarea name="description" rows="3" class="field-input" <%= canManage ? '' : 'disabled' %>><%= category.description || '' %></textarea>
                </div>
                <div class="grid gap-4 md:grid-cols-2">
                  <div>
                    <label class="field-label"><%= t('access.sortOrder') %></label>
                    <input name="sortOrder" type="number" min="0" class="field-input" value="<%= category.sort_order %>" <%= canManage ? '' : 'disabled' %> />
                  </div>
                  <label class="flex items-center gap-3 rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700">
                    <input type="checkbox" name="isActive" <%= category.is_active ? 'checked' : '' %> <%= canManage ? '' : 'disabled' %> />
                    <%= t('access.typeActive') %>
                  </label>
                </div>
                <% if (canManage) { %>
                  <div class="flex flex-wrap gap-3">
                    <button type="submit" class="btn-secondary"><%= t('access.saveType') %></button>
                    <button formaction="/events/<%= activeEvent.id %>/<%= accessType %>/types/<%= category.id %>?_method=DELETE" formmethod="POST" class="btn-danger"><%= t('access.deleteType') %></button>
                  </div>
                <% } %>
              </div>
            </form>
          <% }) %>
        </div>
      </div>

      <div class="shell-card overflow-hidden">
        <div class="flex flex-col gap-3 border-b border-slate-200/80 px-5 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-6">
          <div>
            <h2 class="text-xl font-bold text-slate-900"><%= t('requestProfiles.title') %></h2>
            <p class="mt-1 text-sm text-slate-500"><%= t('requestProfiles.shortDescription') %></p>
          </div>
          <% if (canManage) { %>
            <a href="/events/<%= activeEvent.id %>/request-profiles" class="btn-secondary"><%= t('requestProfiles.manageButton') %></a>
          <% } %>
        </div>

        <div class="space-y-4 px-5 py-5 sm:px-6" data-live-section="access-profiles">
          <% if (!profiles.length) { %>
            <p class="text-sm text-slate-500"><%= t('requestProfiles.none') %></p>
          <% } %>

          <% profiles.forEach((profile) => { %>
            <article class="rounded-2xl border border-slate-200 p-4">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <p class="text-sm font-bold text-slate-900"><%= profile.name %></p>
                    <span class="status-<%= profile.is_active ? 'active' : 'archived' %>"><%= profile.is_active ? t('common.active') : t('common.inactive') %></span>
                  </div>
                  <p class="mt-2 text-sm text-slate-500">/p · <%= t('requestProfiles.fields.codeEntryHint') %></p>
                </div>
                <% if (canManage) { %>
                  <a href="/events/<%= activeEvent.id %>/request-profiles" class="btn-secondary"><%= t('requestProfiles.openManager') %></a>
                <% } %>
              </div>
              <div class="mt-4 flex flex-wrap gap-2">
                <% profile.quotaUsage.forEach((quota) => { %>
                  <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
                    <%= quota.category_name %>: <%= quota.used_count %>/<%= quota.quota %> · <%= t('requestProfiles.remaining', { count: quota.remaining_count }) %>
                  </span>
                <% }) %>
              </div>
            </article>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="shell-card overflow-hidden">
      <div class="flex flex-col gap-3 border-b border-slate-200/80 px-5 py-5 sm:px-6">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <h2 class="text-xl font-bold text-slate-900"><%= t('access.requestTableTitle', { type: typeTitle }) %></h2>
            <p class="mt-1 text-sm text-slate-500"><%= t('access.requestTableDescription', { type: typeLabel }) %></p>
          </div>
        </div>

        <form method="GET" action="/events/<%= activeEvent.id %>/<%= routeBase %>" class="grid gap-3 lg:grid-cols-4">
          <input name="q" value="<%= filters.query %>" class="field-input" placeholder="<%= t('access.filters.search') %>" />
          <select name="profileId" class="field-input">
            <option value=""><%= t('access.filters.allProfiles') %></option>
            <% profiles.forEach((profile) => { %>
              <option value="<%= profile.id %>" <%= Number(filters.profileId) === Number(profile.id) ? 'selected' : '' %>><%= profile.name %></option>
            <% }) %>
          </select>
          <select name="categoryId" class="field-input">
            <option value=""><%= t('access.filters.allTypes') %></option>
            <% categories.forEach((category) => { %>
              <option value="<%= category.id %>" <%= Number(filters.categoryId) === Number(category.id) ? 'selected' : '' %>><%= category.name %></option>
            <% }) %>
          </select>
          <select name="status" class="field-input">
            <option value=""><%= t('access.filters.allStatuses') %></option>
            <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>><%= t('statuses.pending') %></option>
            <option value="handed_out" <%= filters.status === 'handed_out' ? 'selected' : '' %>><%= t('statuses.handed_out') %></option>
          </select>
          <input name="company" value="<%= filters.company %>" class="field-input lg:col-span-3" placeholder="<%= t('access.filters.company') %>" />
          <div class="flex gap-2">
            <button type="submit" class="btn-primary w-full"><%= t('buttons.filter') %></button>
            <a href="/events/<%= activeEvent.id %>/<%= routeBase %>" class="btn-secondary w-full"><%= t('buttons.reset') %></a>
          </div>
        </form>
      </div>

      <div class="px-5 py-5 sm:px-6" data-live-section="access-requests">
        <% if (!requests.length) { %>
          <p class="text-sm text-slate-500"><%= t('access.noRequests', { type: typeTitle }) %></p>
        <% } else { %>
          <div class="space-y-4">
            <% requests.forEach((request) => { %>
              <article class="rounded-2xl border border-slate-200 p-4">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <p class="text-sm font-bold text-slate-900"><%= request.full_name %></p>
                      <span class="status-<%= request.status === 'handed_out' ? 'active' : 'pending' %>"><%= t(`statuses.${request.status}`) %></span>
                    </div>
                    <div class="mt-3 grid gap-2 text-sm text-slate-600 sm:grid-cols-2">
                      <p><strong><%= t('access.fields.type') %>:</strong> <%= request.category_name %></p>
                      <p><strong><%= t('access.fields.profile') %>:</strong> <%= request.profile_name || t('common.notSet') %></p>
                      <p><strong><%= t('access.fields.company') %>:</strong> <%= request.company_name || t('common.notSet') %></p>
                      <p><strong><%= t('access.fields.phone') %>:</strong> <%= request.phone || t('common.notSet') %></p>
                      <p><strong><%= t('field.email') %>:</strong> <%= request.email || t('common.notSet') %></p>
                      <p><strong><%= t('access.fields.updated') %>:</strong> <%= helpers.formatDateTime(request.updated_at) %></p>
                      <% if (request.handed_out_at) { %>
                        <p class="sm:col-span-2"><strong><%= t('access.fields.handedOutBy') %>:</strong> <%= request.handed_out_by_name || t('audit.actor.system') %> · <%= helpers.formatDateTime(request.handed_out_at) %></p>
                      <% } %>
                    </div>
                    <% if (request.notes) { %>
                      <p class="mt-3 text-sm text-slate-500"><%= request.notes %></p>
                    <% } %>
                  </div>

                  <form action="/events/<%= activeEvent.id %>/<%= accessType %>/requests/<%= request.id %>/status?_method=PUT" method="POST" class="flex flex-col gap-2 min-w-[140px]">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <% if (request.status === 'handed_out') { %>
                      <input type="hidden" name="status" value="pending" />
                      <button type="submit" class="btn-secondary"><%= t('access.actions.markPending') %></button>
                    <% } else { %>
                      <input type="hidden" name="status" value="handed_out" />
                      <button type="submit" class="btn-primary"><%= t('access.actions.markHandedOut') %></button>
                    <% } %>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
