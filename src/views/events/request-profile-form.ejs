<%
  const isEditMode = Boolean(editingProfile);
  const formAction = isEditMode
    ? `/events/${activeEvent.id}/request-profiles/${editingProfile.id}?_method=PUT`
    : `/events/${activeEvent.id}/request-profiles`;
  const passQuotaMap = editingProfile?.passQuotaMap || {};
  const wristbandQuotaMap = editingProfile?.wristbandQuotaMap || {};
%>

<section class="request-profile-page request-profile-page--form space-y-6">
  <section class="shell-card request-profile-editor request-profile-editor--compact">
    <div class="request-profile-editor__head">
      <div>
        <p class="request-profile-editor__eyebrow"><%= t('requestProfiles.nav.create') %></p>
        <h1 class="request-profile-editor__title"><%= isEditMode ? t('requestProfiles.editorEditTitle') : t('requestProfiles.editorCreateTitle') %></h1>
        <p class="request-profile-editor__description"><%= isEditMode ? t('requestProfiles.editorEditDescription') : t('requestProfiles.editorCreateDescription') %></p>
      </div>
      <span class="<%= isEditMode && !editingProfile.is_active ? 'status-archived' : 'status-active' %> request-profile-editor__status">
        <%= isEditMode && !editingProfile.is_active ? t('common.inactive') : t('common.active') %>
      </span>
    </div>

    <form id="request-profile-form" action="<%= formAction %>" method="POST" class="request-profile-editor__form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="request-profile-editor__fields request-profile-editor__fields--compact">
        <div>
          <label class="field-label" for="request-profile-name"><%= t('requestProfiles.fields.name') %></label>
          <input
            id="request-profile-name"
            name="name"
            type="text"
            class="field-input"
            required
            value="<%= editingProfile?.name || '' %>"
          />
        </div>

        <div>
          <label class="field-label" for="request-profile-contact-email"><%= t('field.email') %></label>
          <input
            id="request-profile-contact-email"
            name="contactEmail"
            type="email"
            class="field-input"
            value="<%= editingProfile?.contact_email || '' %>"
          />
        </div>

        <div>
          <label class="field-label" for="request-profile-contact-phone"><%= t('portal.fields.phone') %></label>
          <input
            id="request-profile-contact-phone"
            name="contactPhone"
            type="text"
            class="field-input"
            value="<%= editingProfile?.contact_phone || '' %>"
          />
        </div>

        <div>
          <label class="field-label" for="request-profile-notes"><%= t('requestProfiles.fields.notes') %></label>
          <textarea id="request-profile-notes" name="notes" rows="1" class="field-input"><%= editingProfile?.notes || '' %></textarea>
        </div>

        <label class="request-profile-toggle">
          <input type="checkbox" name="isActive" <%= !isEditMode || editingProfile.is_active ? 'checked' : '' %> />
          <span><%= t('requestProfiles.fields.active') %></span>
        </label>

        <label class="request-profile-toggle">
          <input type="checkbox" name="notifyContactOnCreate" <%= !isEditMode || editingProfile?.notify_contact_on_create ? 'checked' : '' %> />
          <span><%= t('requestProfiles.fields.sendInvite') %></span>
        </label>

        <label class="request-profile-toggle request-profile-toggle--wide">
          <input
            type="checkbox"
            name="unlimitedQuota"
            data-request-profile-unlimited-toggle
            <%= editingProfile?.is_unlimited_quota ? 'checked' : '' %>
          />
          <span>
            <strong><%= t('requestProfiles.fields.unlimitedQuota') %></strong>
            <small><%= t('requestProfiles.fields.unlimitedQuotaHelp') %></small>
          </span>
        </label>
      </div>

      <% if (isEditMode) { %>
        <div class="request-profile-editor__meta">
          <div class="request-profile-meta-field">
            <label class="field-label" for="request-profile-code"><%= t('requestProfiles.editorAccessCode') %></label>
            <div class="request-profile-inline-input">
              <input id="request-profile-code" type="text" class="field-input" readonly value="<%= editingProfile.access_code || '' %>" />
            </div>
          </div>

          <div class="request-profile-meta-field">
            <label class="field-label" for="request-profile-link"><%= t('requestProfiles.editorInviteLink') %></label>
            <div class="request-profile-inline-input">
              <input id="request-profile-link" type="text" class="field-input" readonly value="<%= editingProfile.invite_url || '' %>" />
              <button
                type="button"
                class="table-icon-button"
                data-copy-text="<%= editingProfile.invite_url || '' %>"
                data-copy-success-message="<%= t('requestProfiles.copySuccess') %>"
                title="<%= t('requestProfiles.copyInviteLink') %>"
              >
                <svg viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M7 3.5A2.5 2.5 0 0 1 9.5 1h6A2.5 2.5 0 0 1 18 3.5v6A2.5 2.5 0 0 1 15.5 12h-6A2.5 2.5 0 0 1 7 9.5zM4.5 6A2.5 2.5 0 0 0 2 8.5v6A2.5 2.5 0 0 0 4.5 17h6A2.5 2.5 0 0 0 13 14.5V14" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      <% } %>

      <div class="request-profile-help panel">
        <p class="request-profile-help__title"><%= t('requestProfiles.helpTitle') %></p>
        <p class="request-profile-help__body"><%= t('requestProfiles.editorFooter') %></p>
      </div>

      <div class="request-profile-help panel hidden" data-request-profile-unlimited-note>
        <p class="request-profile-help__title"><%= t('requestProfiles.unlimited') %></p>
        <p class="request-profile-help__body"><%= t('requestProfiles.fields.unlimitedQuotaHelp') %></p>
      </div>

      <div class="request-profile-editor__quotas" data-request-profile-quotas>
        <section class="request-profile-quota-card panel">
          <div class="request-profile-quota-card__head">
            <div>
              <h2><%= t('nav.wristbands') %></h2>
            </div>
          </div>

          <div class="request-profile-quota-list">
            <% if (!wristbandCategories.length) { %>
              <p class="request-profile-quota-card__empty"><%= t('requestProfiles.noWristbandTypes') %></p>
            <% } %>

            <% wristbandCategories.forEach((category) => { %>
              <label class="request-profile-quota-row">
                <span class="request-profile-quota-row__copy">
                  <span class="request-profile-quota-row__title"><%= category.name %></span>
                  <span class="request-profile-quota-row__description"><%= category.description || t('common.noDescription') %></span>
                </span>
                <input
                  name="wristbandQuota[<%= category.id %>]"
                  type="number"
                  min="0"
                  class="field-input request-profile-quota-input"
                  data-request-profile-quota-input
                  value="<%= Number(wristbandQuotaMap[category.id] || 0) %>"
                />
              </label>
            <% }) %>
          </div>
        </section>

        <section class="request-profile-quota-card panel">
          <div class="request-profile-quota-card__head">
            <div>
              <h2><%= t('nav.passes') %></h2>
            </div>
          </div>

          <div class="request-profile-quota-list">
            <% if (!passCategories.length) { %>
              <p class="request-profile-quota-card__empty"><%= t('requestProfiles.noPassTypes') %></p>
            <% } %>

            <% passCategories.forEach((category) => { %>
              <label class="request-profile-quota-row">
                <span class="request-profile-quota-row__copy">
                  <span class="request-profile-quota-row__title"><%= category.name %></span>
                  <span class="request-profile-quota-row__description"><%= category.description || t('common.noDescription') %></span>
                </span>
                <input
                  name="passQuota[<%= category.id %>]"
                  type="number"
                  min="0"
                  class="field-input request-profile-quota-input"
                  data-request-profile-quota-input
                  value="<%= Number(passQuotaMap[category.id] || 0) %>"
                />
              </label>
            <% }) %>
          </div>
        </section>
      </div>
    </form>

    <div class="request-profile-editor__actions">
      <a href="/events/<%= activeEvent.id %>/request-profiles" class="btn-secondary"><%= t('requestProfiles.backToList') %></a>

      <div class="request-profile-editor__actions-right">
        <% if (isEditMode) { %>
          <form action="/events/<%= activeEvent.id %>/request-profiles/<%= editingProfile.id %>/regenerate-code" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="btn-secondary"><%= t('requestProfiles.regenerateCode') %></button>
          </form>

          <form action="/events/<%= activeEvent.id %>/request-profiles/<%= editingProfile.id %>?_method=DELETE" method="POST" data-confirm-message="<%= t('common.confirmDelete') %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="btn-danger"><%= t('requestProfiles.deleteButton') %></button>
          </form>
        <% } %>

        <button type="submit" form="request-profile-form" class="btn-primary">
          <%= isEditMode ? t('requestProfiles.saveButton') : t('requestProfiles.createButton') %>
        </button>
      </div>
    </div>
  </section>
</section>
