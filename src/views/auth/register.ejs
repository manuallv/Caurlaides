<section class="mx-auto max-w-5xl">
  <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
    <div class="shell-card p-6 sm:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-700"><%= t('auth.register.startHere') %></p>
      <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900"><%= t('auth.register.heroTitle') %></h1>
      <p class="mt-3 text-sm leading-6 text-slate-600">
        <%= t('auth.register.heroDescription') %>
      </p>
    </div>

    <div class="shell-card p-6 sm:p-8">
      <h2 class="text-2xl font-bold text-slate-900"><%= t('auth.register.title') %></h2>

      <form action="/register" method="POST" class="mt-6 space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div>
          <label for="fullName" class="field-label"><%= t('field.fullName') %></label>
          <input id="fullName" name="fullName" type="text" class="field-input" required />
        </div>

        <div>
          <label for="email" class="field-label"><%= t('field.email') %></label>
          <input id="email" name="email" type="email" class="field-input" required />
        </div>

        <div>
          <label for="password" class="field-label"><%= t('field.password') %></label>
          <input id="password" name="password" type="password" class="field-input" required />
          <p class="field-help"><%= t('validation.auth.passwordLength', { min: 8 }) %></p>
        </div>

        <div>
          <label for="confirmPassword" class="field-label"><%= t('field.confirmPassword') %></label>
          <input id="confirmPassword" name="confirmPassword" type="password" class="field-input" required />
        </div>

        <button type="submit" class="btn-primary w-full"><%= t('auth.register.title') %></button>
      </form>

      <p class="mt-6 text-sm text-slate-500">
        <%= t('auth.register.haveAccount') %>
        <a href="/login" class="font-semibold text-brand-700 hover:text-brand-800"><%= t('auth.register.loginHere') %></a>
      </p>
    </div>
  </div>
</section>
