<%
  const passPrintState = JSON.stringify({
    canManage,
    template: {
      name: template.name || '',
      backgroundUrl: template.backgroundUrl || '',
      fields: template.fields || [],
    },
    variables: variableDefinitions || [],
  });
%>

<section
  class="space-y-5"
  data-pass-print-app
  data-pass-print-can-manage="<%= canManage ? 'true' : 'false' %>"
  data-pass-print-state-script="pass-print-state"
  data-pass-print-empty-label="<%= t('passPrint.empty') %>"
  data-pass-print-selected-title="<%= t('passPrint.editor.selectedField') %>"
  data-pass-print-no-selection="<%= t('passPrint.editor.noSelection') %>"
  data-pass-print-preview-title="<%= t('passPrint.editor.previewTitle') %>"
>
  <div class="shell-card overflow-hidden">
    <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
      <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
        <div>
          <p class="worldnic-eyebrow"><%= t('event.sidebar.autoPasses') %></p>
          <h1 class="mt-3 text-2xl font-bold text-slate-900"><%= t('passPrint.title') %></h1>
          <p class="mt-2 text-sm text-slate-500"><%= t('passPrint.description') %></p>
        </div>

        <% if (!canManage) { %>
          <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            <%= t('passPrint.readOnlyHint') %>
          </div>
        <% } %>
      </div>

      <div class="pass-print-tabs mt-5">
        <button type="button" class="pass-print-tab is-active" data-pass-print-tab="editor"><%= t('passPrint.tabs.editor') %></button>
        <button type="button" class="pass-print-tab" data-pass-print-tab="print"><%= t('passPrint.tabs.print') %></button>
      </div>
    </div>

    <div class="px-5 py-5 sm:px-6">
      <div data-pass-print-panel="editor">
        <form
          action="/events/<%= activeEvent.id %>/passes/print/template"
          method="POST"
          enctype="multipart/form-data"
          class="space-y-5"
          data-pass-print-form
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="templateFields" value="" data-pass-print-fields-input />

          <div class="pass-print-toolbar">
            <div>
              <label class="field-label" for="pass-print-template-name"><%= t('passPrint.editor.templateName') %></label>
              <input
                id="pass-print-template-name"
                name="templateName"
                type="text"
                class="field-input"
                value="<%= template.name %>"
                maxlength="160"
                <%= canManage ? '' : 'disabled' %>
              />
            </div>

            <div>
              <label class="field-label" for="pass-print-background-image"><%= t('passPrint.editor.backgroundImage') %></label>
              <input
                id="pass-print-background-image"
                name="backgroundImage"
                type="file"
                class="field-input"
                accept="image/png,image/jpeg"
                data-pass-print-background-input
                <%= canManage ? '' : 'disabled' %>
              />
            </div>

            <label class="pass-print-remove-toggle">
              <input type="checkbox" name="removeBackground" value="1" data-pass-print-remove-background <%= canManage ? '' : 'disabled' %> />
              <span><%= t('passPrint.editor.removeBackground') %></span>
            </label>

            <% if (canManage) { %>
              <div class="pass-print-toolbar__save">
                <button type="submit" class="btn-primary w-full"><%= t('passPrint.editor.saveTemplate') %></button>
              </div>
            <% } %>
          </div>

          <div class="pass-print-workspace">
            <div class="pass-print-workspace__stage">
              <div class="pass-print-stage-wrap">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="worldnic-eyebrow"><%= t('passPrint.editor.previewLabel') %></p>
                    <h2 class="mt-2 text-lg font-bold text-slate-900"><%= t('passPrint.editor.previewTitle') %></h2>
                  </div>
                  <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">A4</span>
                </div>

                <div class="pass-print-stage">
                  <div
                    class="pass-print-page<%= template.backgroundUrl ? ' has-background' : '' %>"
                    data-pass-print-page
                    style="<%= template.backgroundUrl ? `background-image: url('${template.backgroundUrl}')` : '' %>"
                  >
                    <div class="pass-print-page__grid"></div>
                    <div class="pass-print-page__fields" data-pass-print-field-layer></div>
                    <div class="pass-print-page__empty<%= template.fields.length ? ' hidden' : '' %>" data-pass-print-empty-state>
                      <strong><%= t('passPrint.empty') %></strong>
                      <span><%= t('passPrint.editor.dragHint') %></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="pass-print-workspace__sidebar">
              <div class="pass-print-panel">
                <p class="worldnic-eyebrow"><%= t('passPrint.editor.variablesTitle') %></p>
                <h2 class="mt-2 text-lg font-bold text-slate-900"><%= t('passPrint.editor.variablesSubtitle') %></h2>
                <p class="mt-2 text-sm text-slate-500"><%= t('passPrint.editor.variablesDescription') %></p>

                <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                  <% variableDefinitions.forEach((definition) => { %>
                    <button
                      type="button"
                      class="pass-print-variable-btn"
                      data-pass-print-add-field="<%= definition.type %>"
                      <%= canManage ? '' : 'disabled' %>
                    >
                      <span><%= definition.label %></span>
                      <img src="/public/design-assets/icons/feather/plus.svg" alt="" />
                    </button>
                  <% }) %>
                </div>
              </div>

              <div class="pass-print-panel">
                <p class="worldnic-eyebrow"><%= t('passPrint.editor.selectedField') %></p>
                <h2 class="mt-2 text-lg font-bold text-slate-900" data-pass-print-inspector-title><%= t('passPrint.editor.noSelection') %></h2>

                <div class="mt-4 space-y-4" data-pass-print-inspector>
                  <div>
                    <label class="field-label" for="pass-print-field-type"><%= t('passPrint.editor.variableType') %></label>
                    <select id="pass-print-field-type" class="field-input" data-pass-print-field-type <%= canManage ? '' : 'disabled' %>>
                      <% variableDefinitions.forEach((definition) => { %>
                        <option value="<%= definition.type %>"><%= definition.label %></option>
                      <% }) %>
                    </select>
                  </div>

                  <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                      <label class="field-label" for="pass-print-field-font-size"><%= t('passPrint.editor.fontSize') %></label>
                      <input
                        id="pass-print-field-font-size"
                        type="number"
                        min="8"
                        max="64"
                        step="1"
                        class="field-input"
                        data-pass-print-field-font-size
                        <%= canManage ? '' : 'disabled' %>
                      />
                    </div>

                    <div>
                      <label class="field-label" for="pass-print-field-width"><%= t('passPrint.editor.fieldWidth') %></label>
                      <input
                        id="pass-print-field-width"
                        type="number"
                        min="8"
                        max="90"
                        step="1"
                        class="field-input"
                        data-pass-print-field-width
                        <%= canManage ? '' : 'disabled' %>
                      />
                    </div>
                  </div>

                  <div class="grid gap-3 sm:grid-cols-3">
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                      <span class="text-xs font-semibold uppercase tracking-wide text-slate-400"><%= t('passPrint.editor.positionX') %></span>
                      <p class="mt-2 text-sm font-semibold text-slate-900" data-pass-print-field-position-x>0%</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                      <span class="text-xs font-semibold uppercase tracking-wide text-slate-400"><%= t('passPrint.editor.positionY') %></span>
                      <p class="mt-2 text-sm font-semibold text-slate-900" data-pass-print-field-position-y>0%</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                      <span class="text-xs font-semibold uppercase tracking-wide text-slate-400"><%= t('passPrint.editor.rotation') %></span>
                      <p class="mt-2 text-sm font-semibold text-slate-900" data-pass-print-field-rotation>0°</p>
                    </div>
                  </div>

                  <div class="grid gap-3 sm:grid-cols-2">
                    <% if (canManage) { %>
                      <button type="button" class="btn-secondary w-full" data-pass-print-rotate-field><%= t('passPrint.editor.rotate90') %></button>
                      <button type="button" class="btn-secondary w-full" data-pass-print-remove-field><%= t('passPrint.editor.removeField') %></button>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </form>
      </div>

      <div class="hidden" data-pass-print-panel="print">
        <div class="pass-print-print-shell">
          <div class="pass-print-panel">
            <p class="worldnic-eyebrow"><%= t('passPrint.printTitle') %></p>
            <h2 class="mt-2 text-xl font-bold text-slate-900"><%= t('passPrint.printDescription') %></h2>

            <form action="/events/<%= activeEvent.id %>/passes/print/export" method="GET" class="mt-5 space-y-4">
              <div>
                <label class="field-label" for="pass-print-category-filter"><%= t('passPrint.printFilter') %></label>
                <select id="pass-print-category-filter" name="categoryId" class="field-input">
                  <option value=""><%= t('passPrint.printAllTypes') %></option>
                  <% categories.forEach((category) => { %>
                    <option value="<%= category.id %>" <%= Number(selectedCategoryId) === Number(category.id) ? 'selected' : '' %>>
                      <%= category.name %> (<%= category.total_requests %>)
                    </option>
                  <% }) %>
                </select>
              </div>

              <button type="submit" class="btn-primary"><%= t('passPrint.printSubmit') %></button>
            </form>
          </div>

          <div class="pass-print-panel">
            <p class="worldnic-eyebrow"><%= t('passPrint.printTypesList') %></p>
            <div class="mt-4 space-y-3">
              <% categories.forEach((category) => { %>
                <div class="pass-print-type-row">
                  <div>
                    <strong><%= category.name %></strong>
                    <% if (category.description) { %>
                      <span><%= category.description %></span>
                    <% } %>
                  </div>
                  <span><%= category.total_requests %></span>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script id="pass-print-state" type="application/json"><%- passPrintState %></script>
