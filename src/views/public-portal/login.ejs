<section class="mx-auto max-w-2xl">
  <div class="shell-card overflow-hidden">
    <div class="px-6 py-8 text-center sm:px-10">
      <p class="worldnic-eyebrow"><%= t('portal.eyebrow') %></p>
      <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900"><%= t('portal.login.title') %></h1>
      <p class="mx-auto mt-4 max-w-xl text-sm leading-6 text-slate-600"><%= t('portal.login.description') %></p>
      <div class="worldnic-auth-note mx-auto mt-6 max-w-xl text-left">
        <%= t('portal.login.note') %>
      </div>
    </div>

    <div class="border-t border-slate-200/80 px-6 py-8 sm:px-10">
      <form action="/p/access" method="POST" class="mx-auto max-w-md space-y-4" data-portal-code-form>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div>
          <label class="field-label" for="accessCode"><%= t('portal.fields.accessCode') %></label>
          <input
            id="accessCode"
            name="accessCode"
            type="text"
            class="field-input text-center tracking-[0.28em]"
            autocomplete="one-time-code"
            required
          />
        </div>
        <button type="submit" class="btn-primary w-full"><%= t('portal.login.submit') %></button>
      </form>
    </div>
  </div>
</section>
