<section class="shell-card overflow-hidden">
  <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
    <h1 class="text-2xl font-bold text-slate-900"><%= t('audit.title') %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t('audit.description') %></p>
  </div>

  <div class="space-y-4 px-5 py-5 sm:px-6">
    <% if (!activity.length) { %>
      <p class="text-sm text-slate-500"><%= t('audit.none') %></p>
    <% } %>
    <% activity.forEach((entry) => { %>
      <article class="rounded-2xl border border-slate-200 px-4 py-4">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-semibold text-slate-900"><%= helpers.formatAuditMessage(entry) %></p>
            <p class="mt-1 text-xs uppercase tracking-wide text-slate-400">
              <%= entry.actor_name || t('audit.actor.system') %> · <%= helpers.auditEntityLabel(entry.entity_type) %> · <%= helpers.auditActionLabel(entry.action) %>
            </p>
          </div>
          <p class="text-sm text-slate-500"><%= helpers.formatDateTime(entry.created_at) %></p>
        </div>
      </article>
    <% }) %>
  </div>
</section>
