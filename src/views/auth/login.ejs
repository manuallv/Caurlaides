<%
  const localeHref = (code) => `/language/${code}?redirect=${encodeURIComponent(currentPath || '/')}`;
%>

<section class="authincation worldnic-auth-shell">
  <aside class="login-aside worldnic-auth-aside">
    <a href="/login" class="worldnic-auth-brand">
      <span class="worldnic-brand__badge">
        <img src="/public/design-assets/brand/logo.png" alt="<%= t('app.name') %>" />
      </span>
      <span class="worldnic-brand__copy">
        <strong><%= t('app.name') %></strong>
        <small><%= t('app.tagline') %></small>
      </span>
    </a>

    <div class="worldnic-auth-copy">
      <p class="worldnic-eyebrow"><%= t('auth.portal') %></p>
      <h1><%= t('auth.login.heroTitle') %></h1>
      <p><%= t('auth.login.heroDescription') %></p>

      <div class="worldnic-auth-kpis">
        <article class="worldnic-auth-kpi">
          <strong><%= t('auth.login.panel.multiUser.title') %></strong>
          <span><%= t('auth.login.panel.multiUser.body') %></span>
        </article>
        <article class="worldnic-auth-kpi">
          <strong><%= t('auth.login.panel.history.title') %></strong>
          <span><%= t('auth.login.panel.history.body') %></span>
        </article>
        <article class="worldnic-auth-kpi">
          <strong><%= t('auth.login.panel.mobile.title') %></strong>
          <span><%= t('auth.login.panel.mobile.body') %></span>
        </article>
      </div>
    </div>

    <div class="worldnic-auth-illustration aside-image" style="background-image: url('/public/design-assets/worldnic/pic1.svg')"></div>
  </aside>

  <div class="worldnic-auth-main">
    <div class="authincation-content style-2 worldnic-auth-card">
      <div class="worldnic-auth-topbar">
        <div>
          <p class="worldnic-eyebrow"><%= t('auth.portal') %></p>
          <h2 class="worldnic-auth-heading"><%= t('auth.login.title') %></h2>
        </div>

        <div class="worldnic-locale">
          <% supportedLocales.forEach((languageCode) => { %>
            <a href="<%= localeHref(languageCode) %>" class="<%= locale === languageCode ? 'is-active' : '' %>">
              <%= languageCode.toUpperCase() %>
            </a>
          <% }) %>
        </div>
      </div>

      <div class="auth-form worldnic-auth-form">
        <%- include('../partials/flash') %>
        <p class="worldnic-auth-subcopy"><%= t('auth.login.description') %></p>

        <form action="/login" method="POST" class="space-y-4">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div>
            <label for="email" class="field-label"><%= t('field.email') %></label>
            <input id="email" name="email" type="email" class="field-input" autocomplete="email" required />
          </div>

          <div>
            <label for="password" class="field-label"><%= t('field.password') %></label>
            <input id="password" name="password" type="password" class="field-input" autocomplete="current-password" required />
          </div>

          <button type="submit" class="btn-primary"><%= t('auth.login.title') %></button>
        </form>

        <div class="worldnic-auth-note">
          <%= t('auth.login.panel.mobile.body') %>
        </div>

        <p class="worldnic-auth-footer">
          <%= t('auth.login.needAccount') %>
          <a href="/register"><%= t('auth.login.createHere') %></a>
        </p>
      </div>
    </div>
  </div>
</section>
