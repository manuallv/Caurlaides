<section
  class="portal-page portal-page-workspace"
  data-portal-app
  data-portal-table-title="<%= t('portal.tableTitle') %>"
  data-portal-table-description="<%= t('portal.tableDescription') %>"
  data-portal-request-description="<%= t('portal.manage.description') %>"
  data-portal-import-description="<%= t('portal.manage.description') %>"
  data-portal-summary-expand-label="<%= t('portal.summaryExpand') %>"
  data-portal-summary-collapse-label="<%= t('portal.summaryCollapse') %>"
>
  <script id="portal-state" type="application/json"><%- JSON.stringify(portalClientState) %></script>

  <div class="portal-page-stack">
    <section class="portal-summary-grid" data-live-section="portal-summary">
      <article class="portal-access-card panel" data-portal-summary-card data-portal-summary-type="wristband">
        <div class="portal-access-card__mobile-bar">
          <div class="portal-access-card__mobile-copy">
            <h2><%= t('nav.wristbands') %></h2>
          </div>
          <div class="portal-access-card__mobile-actions">
            <button type="button" class="btn-primary portal-access-card__mobile-primary" data-portal-open-request-panel data-request-type="wristband"><%= t('portal.addWristbandButton') %></button>
            <button
              type="button"
              class="portal-access-card__mobile-toggle"
              data-portal-summary-toggle
              aria-expanded="false"
              aria-controls="portal-summary-wristband"
              aria-label="<%= t('portal.summaryExpand') %>"
            >
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="m5.4 7.7 4.6 4.6 4.6-4.6 1.1 1.1-5.7 5.7-5.7-5.7z" />
              </svg>
            </button>
          </div>
        </div>

        <div class="portal-access-card__content" id="portal-summary-wristband" data-portal-summary-content>
          <div class="portal-access-card__head">
            <div class="portal-access-card__copy">
              <h2><%= t('nav.wristbands') %></h2>
              <p><%= t('portal.sectionDescriptionWristbands') %></p>
            </div>
            <span class="portal-state-pill <%= wristbandPortalOpen ? 'is-open' : 'is-closed' %>">
              <%= wristbandPortalOpen ? t('portal.openForChanges') : t('portal.closedForChanges') %>
            </span>
          </div>

          <div class="portal-quota-list">
            <% if (!wristbandQuotaUsage.length) { %>
              <p class="portal-empty-copy"><%= t('portal.noWristbandQuota') %></p>
            <% } %>
            <% wristbandQuotaUsage.forEach((quota) => { %>
              <span class="portal-quota-chip">
                <% if (quota.is_unlimited) { %>
                  <%= quota.category_name %>: <%= quota.used_count %> · <%= t('requestProfiles.unlimited') %>
                <% } else { %>
                  <%= quota.category_name %>: <%= quota.used_count %>/<%= quota.quota %> · <%= t('requestProfiles.remaining', { count: quota.remaining_count }) %>
                <% } %>
              </span>
            <% }) %>
          </div>

          <div class="portal-card-actions">
            <button type="button" class="btn-primary portal-card-actions__primary" data-portal-open-request-panel data-request-type="wristband"><%= t('portal.addWristbandButton') %></button>
            <button type="button" class="btn-secondary" data-portal-set-tab data-tab="wristband"><%= t('portal.manageWristbandButton') %></button>
            <button type="button" class="btn-secondary" data-portal-open-import-panel data-request-type="wristband"><%= t('portal.importWristbandButton') %></button>
          </div>
        </div>
      </article>

      <article class="portal-access-card panel" data-portal-summary-card data-portal-summary-type="pass">
        <div class="portal-access-card__mobile-bar">
          <div class="portal-access-card__mobile-copy">
            <h2><%= t('nav.passes') %></h2>
          </div>
          <div class="portal-access-card__mobile-actions">
            <button type="button" class="btn-primary portal-access-card__mobile-primary" data-portal-open-request-panel data-request-type="pass"><%= t('portal.addPassButton') %></button>
            <button
              type="button"
              class="portal-access-card__mobile-toggle"
              data-portal-summary-toggle
              aria-expanded="false"
              aria-controls="portal-summary-pass"
              aria-label="<%= t('portal.summaryExpand') %>"
            >
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="m5.4 7.7 4.6 4.6 4.6-4.6 1.1 1.1-5.7 5.7-5.7-5.7z" />
              </svg>
            </button>
          </div>
        </div>

        <div class="portal-access-card__content" id="portal-summary-pass" data-portal-summary-content>
          <div class="portal-access-card__head">
            <div class="portal-access-card__copy">
              <h2><%= t('nav.passes') %></h2>
              <p><%= t('portal.sectionDescriptionPasses') %></p>
            </div>
            <span class="portal-state-pill <%= passPortalOpen ? 'is-open' : 'is-closed' %>">
              <%= passPortalOpen ? t('portal.openForChanges') : t('portal.closedForChanges') %>
            </span>
          </div>

          <div class="portal-quota-list">
            <% if (!passQuotaUsage.length) { %>
              <p class="portal-empty-copy"><%= t('portal.noPassQuota') %></p>
            <% } %>
            <% passQuotaUsage.forEach((quota) => { %>
              <span class="portal-quota-chip">
                <% if (quota.is_unlimited) { %>
                  <%= quota.category_name %>: <%= quota.used_count %> · <%= t('requestProfiles.unlimited') %>
                <% } else { %>
                  <%= quota.category_name %>: <%= quota.used_count %>/<%= quota.quota %> · <%= t('requestProfiles.remaining', { count: quota.remaining_count }) %>
                <% } %>
              </span>
            <% }) %>
          </div>

          <div class="portal-card-actions">
            <button type="button" class="btn-primary portal-card-actions__primary" data-portal-open-request-panel data-request-type="pass"><%= t('portal.addPassButton') %></button>
            <button type="button" class="btn-secondary" data-portal-set-tab data-tab="pass"><%= t('portal.managePassButton') %></button>
            <button type="button" class="btn-secondary" data-portal-open-import-panel data-request-type="pass"><%= t('portal.importPassButton') %></button>
          </div>
        </div>
      </article>
    </section>

    <section class="shell-card portal-workspace-card">
      <div class="portal-workspace-card__header">
        <div class="portal-workspace-card__copy">
          <p class="worldnic-eyebrow"><%= t('portal.manage.title') %></p>
          <h2 data-portal-workspace-title><%= t('portal.tableTitle') %></h2>
          <p data-portal-workspace-description><%= t('portal.tableDescription') %></p>
        </div>

        <div class="portal-workspace-card__actions">
          <button type="button" class="btn-secondary hidden" data-portal-back-to-table><%= t('portal.tableTitle') %></button>
        </div>
      </div>

      <div class="portal-workspace-card__body">
        <section class="portal-workspace-view is-active" data-portal-view-panel="table" data-live-section="portal-table">
          <div class="portal-table-toolbar">
            <div class="request-profile-search portal-table-search">
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M8.5 3a5.5 5.5 0 1 1 0 11 5.5 5.5 0 0 1 0-11Zm0 1.6a3.9 3.9 0 1 0 0 7.8 3.9 3.9 0 0 0 0-7.8Zm5.38 8.64 3.02 3.02-1.13 1.13-3.02-3.02z" />
              </svg>
              <input
                type="search"
                class="field-input"
                placeholder="<%= t('portal.tableSearch') %>"
                data-portal-table-search
              />
            </div>
            <div class="portal-table-controls">
              <div class="portal-table-sort-card">
                <p class="portal-table-toolbar-label"><%= t('portal.sort.label') %></p>
                <div class="portal-table-sort">
                  <select id="portal-table-sort" class="field-input" data-portal-table-sort>
                    <option value="updated"><%= t('portal.sort.updated') %></option>
                    <option value="name"><%= t('portal.sort.name') %></option>
                    <option value="email"><%= t('portal.sort.email') %></option>
                    <option value="phone"><%= t('portal.sort.phone') %></option>
                    <option value="company"><%= t('portal.sort.company') %></option>
                    <option value="category"><%= t('portal.sort.category') %></option>
                    <option value="status"><%= t('portal.sort.status') %></option>
                  </select>
                  <button type="button" class="btn-secondary portal-sort-direction" data-portal-sort-direction>
                    <span data-portal-sort-direction-label><%= t('portal.sort.directionDesc') %></span>
                  </button>
                </div>
              </div>
              <div class="portal-table-tabs">
                <button type="button" class="portal-tab-button" data-portal-tab data-tab="all"><%= t('portal.tabs.all') %></button>
                <button type="button" class="portal-tab-button" data-portal-tab data-tab="wristband"><%= t('portal.tabs.wristbands') %></button>
                <button type="button" class="portal-tab-button" data-portal-tab data-tab="pass"><%= t('portal.tabs.passes') %></button>
              </div>
            </div>
          </div>

          <div class="portal-table-scroll">
            <% if (!combinedRequests.length) { %>
              <p class="portal-empty-copy portal-empty-copy-table"><%= t('portal.noRequestsCombined') %></p>
            <% } else { %>
              <table class="portal-requests-table" data-portal-table>
                <colgroup>
                  <col class="portal-col-type" />
                  <col class="portal-col-name" />
                  <col class="portal-col-category" />
                  <col class="portal-col-company" />
                  <col class="portal-col-phone" />
                  <col class="portal-col-status" />
                  <col class="portal-col-updated" />
                  <col class="portal-col-actions" />
                </colgroup>
                <thead>
                  <tr>
                    <th><%= t('portal.table.type') %></th>
                    <th><%= t('portal.table.name') %></th>
                    <th><%= t('portal.table.category') %></th>
                    <th><%= t('portal.table.company') %></th>
                    <th><%= t('portal.table.phone') %></th>
                    <th><%= t('portal.table.status') %></th>
                    <th><%= t('portal.table.updated') %></th>
                    <th><%= t('portal.table.actions') %></th>
                  </tr>
                </thead>
                <tbody>
                  <% combinedRequests.forEach((request) => { %>
                    <tr
                      class="portal-request-row"
                      data-request-row
                      data-request-type="<%= request.request_type %>"
                      data-request-search="<%= [request.full_name, request.category_name, request.company_name || '', request.phone || '', request.email || '', request.vehicle_plate || '', request.notes || ''].join(' ').toLowerCase() %>"
                      data-sort-name="<%= (request.full_name || '').toLowerCase() %>"
                      data-sort-email="<%= (request.email || '').toLowerCase() %>"
                      data-sort-phone="<%= (request.phone || '').toLowerCase() %>"
                      data-sort-company="<%= (request.company_name || '').toLowerCase() %>"
                      data-sort-category="<%= (request.category_name || '').toLowerCase() %>"
                      data-sort-status="<%= (request.status || '').toLowerCase() %>"
                      data-sort-updated="<%= new Date(request.updated_at).getTime() || 0 %>"
                    >
                      <td>
                        <span class="portal-type-pill <%= request.request_type === 'pass' ? 'is-pass' : 'is-wristband' %>">
                          <%= t(request.request_type === 'pass' ? 'nav.passes' : 'nav.wristbands') %>
                        </span>
                      </td>
                      <td>
                        <div class="portal-person-cell">
                          <p class="portal-person-cell__title"><%= request.full_name %></p>
                          <% if (request.email) { %>
                            <p class="portal-person-cell__meta"><%= request.email %></p>
                          <% } %>
                          <% if (request.request_type === 'pass' && request.vehicle_plate) { %>
                            <p class="portal-person-cell__meta"><%= t('portal.fields.vehiclePlate') %>: <%= request.vehicle_plate %></p>
                          <% } %>
                        </div>
                      </td>
                      <td><div class="portal-data-cell"><%= request.category_name %></div></td>
                      <td><div class="portal-data-cell"><%= request.company_name || t('common.notSet') %></div></td>
                      <td><div class="portal-data-cell"><%= request.phone || t('common.notSet') %></div></td>
                      <td>
                        <div class="portal-status-stack">
                          <span class="portal-status-pill <%= request.status === 'handed_out' ? 'is-locked' : 'is-pending' %>"><%= t(`statuses.${request.status}`) %></span>
                          <% if (request.request_type === 'pass' && request.entered_at) { %>
                            <span class="text-xs text-slate-500"><%= t('portal.enteredAt') %>: <%= helpers.formatDateTime(request.entered_at) %></span>
                          <% } %>
                        </div>
                      </td>
                      <td>
                        <div class="portal-updated-cell">
                          <span><%= helpers.formatDateTime(request.updated_at) %></span>
                        </div>
                      </td>
                      <td>
                        <div class="portal-row-actions">
                          <% if (request.isEditable) { %>
                            <button
                              type="button"
                              class="portal-action-button"
                              data-portal-edit-request
                              data-request-id="<%= request.id %>"
                              data-request-type="<%= request.request_type %>"
                              data-category-id="<%= request.category_id %>"
                              data-full-name="<%= request.full_name %>"
                              data-company-name="<%= request.company_name || '' %>"
                              data-phone="<%= request.phone || '' %>"
                              data-email="<%= request.email || '' %>"
                              data-vehicle-plate="<%= request.vehicle_plate || '' %>"
                              data-notes="<%= request.notes || '' %>"
                            ><%= t('portal.editRequest') %></button>

                            <form action="/p/<%= request.request_type %>/<%= request.id %>?_method=DELETE" method="POST" data-live-form data-confirm-message="<%= t('common.confirmDelete') %>">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <button type="submit" class="portal-action-button portal-action-button-danger"><%= t('portal.deleteRequest') %></button>
                            </form>
                          <% } else { %>
                            <span class="portal-lock-label"><%= t('portal.requestLockedShort') %></span>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
        </section>

        <section class="portal-workspace-view" data-portal-view-panel="request">
          <form action="/p/pass" method="POST" class="portal-inline-form" data-portal-request-form data-live-form>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div data-portal-method-holder></div>

            <div class="portal-form-grid">
              <div class="portal-form-grid__full">
                <label class="field-label"><%= t('access.fields.type') %></label>
                <select name="categoryId" class="field-input" data-portal-category-select required></select>
              </div>
              <div>
                <label class="field-label"><%= t('portal.fields.fullName') %></label>
                <input name="fullName" type="text" class="field-input" required />
              </div>
              <div>
                <label class="field-label"><%= t('portal.fields.phone') %></label>
                <input name="phone" type="text" class="field-input" />
              </div>
              <div>
                <label class="field-label"><%= t('portal.fields.company') %></label>
                <input name="companyName" type="text" class="field-input" />
              </div>
              <div>
                <label class="field-label"><%= t('field.email') %></label>
                <input name="email" type="email" class="field-input" />
              </div>
              <div class="hidden" data-portal-pass-only-field>
                <label class="field-label"><%= t('portal.fields.vehiclePlate') %></label>
                <input name="vehiclePlate" type="text" class="field-input" />
              </div>
              <div class="portal-form-grid__full">
                <label class="field-label"><%= t('portal.fields.notes') %></label>
                <textarea name="notes" rows="6" class="field-input"></textarea>
              </div>
            </div>

            <div class="portal-inline-form__actions">
              <button type="submit" class="btn-primary"><span data-portal-request-submit-label><%= t('portal.addRequest') %></span></button>
              <button type="button" class="btn-secondary" data-portal-back-to-table><%= t('portal.tableTitle') %></button>
            </div>
          </form>
        </section>

        <section class="portal-workspace-view" data-portal-view-panel="import">
          <form class="portal-inline-form" data-portal-import-preview-form>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="type" value="pass" data-portal-import-type />

            <div class="portal-form-grid">
              <div class="portal-form-grid__full">
                <label class="field-label"><%= t('access.fields.type') %></label>
                <select name="categoryId" class="field-input" data-portal-import-category required></select>
              </div>
              <div class="portal-form-grid__full portal-import-tools">
                <a href="#" class="btn-secondary" data-portal-template-link><%= t('portal.downloadTemplate') %></a>
                <input type="file" name="excelFile" accept=".xlsx,.xls" class="field-input" data-portal-import-file required />
              </div>
            </div>

            <div class="portal-inline-form__actions">
              <button type="submit" class="btn-primary"><%= t('portal.previewImport') %></button>
              <button type="button" class="btn-secondary hidden" data-portal-import-confirm><%= t('portal.confirmImport') %></button>
              <button type="button" class="btn-secondary" data-portal-back-to-table><%= t('portal.tableTitle') %></button>
            </div>
          </form>

          <div class="portal-import-preview hidden" data-portal-import-preview></div>
        </section>
      </div>
    </section>
  </div>
</section>
