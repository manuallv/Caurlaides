<!DOCTYPE html>
<html lang="<%= locale %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle ? `${pageTitle} | ${t('app.titleSuffix')}` : t('app.titleSuffix') %></title>
    <link rel="stylesheet" href="/public/css/app.css" />
    <link rel="stylesheet" href="/public/css/worldnic-theme.css" />
  </head>
  <%
    const hasEvent = Boolean(activeEvent);
    const isAuthPage = !currentUser && ['/login', '/register'].includes(currentPath);
    const localeHref = (code) => `/language/${code}?redirect=${encodeURIComponent(currentPath || '/')}`;
    const userInitials = currentUser
      ? currentUser.full_name
          .split(' ')
          .filter(Boolean)
          .slice(0, 2)
          .map((part) => part[0].toUpperCase())
          .join('')
      : '';
    const eventSection = hasEvent
      ? currentPath === `/events/${activeEvent.id}`
        ? 'overview'
        : currentPath.includes('/wristbands')
          ? 'wristbands'
          : currentPath.includes('/passes')
            ? 'passes'
            : currentPath.includes('/request-profiles')
              ? 'profiles'
              : currentPath.includes('/edit') || currentPath.includes('/members') || currentPath.includes('/activity')
                ? 'settings'
                : ''
      : '';
    const sidebarLinks = [
      {
        href: '/dashboard',
        label: t('nav.dashboard'),
        icon: 'grid',
        active: currentPath === '/' || currentPath.startsWith('/dashboard'),
      },
      {
        href: '/events/new',
        label: t('nav.create'),
        icon: 'plus',
        active: currentPath.startsWith('/events/new'),
      },
    ];

    if (hasEvent) {
      sidebarLinks.push(
        {
          href: `/events/${activeEvent.id}`,
          label: t('event.sidebar.overview'),
          icon: 'layers',
          active: eventSection === 'overview',
        },
        {
          href: `/events/${activeEvent.id}/wristbands`,
          label: t('event.sidebar.eventWristbands'),
          icon: 'tag',
          active: eventSection === 'wristbands',
        },
        {
          href: `/events/${activeEvent.id}/passes`,
          label: t('event.sidebar.autoPasses'),
          icon: 'layers',
          active: eventSection === 'passes',
        },
        {
          href: `/events/${activeEvent.id}/request-profiles`,
          label: t('event.sidebar.requestProfiles'),
          icon: 'users',
          active: eventSection === 'profiles',
        },
        {
          href: `/events/${activeEvent.id}/edit`,
          label: t('event.sidebar.settings'),
          icon: 'activity',
          active: eventSection === 'settings',
        },
      );
    }

    const bodyClass = [
      'worldnic-body',
      currentUser ? 'worldnic-body-app' : 'worldnic-body-guest',
      isAuthPage ? 'worldnic-auth-body' : '',
    ]
      .filter(Boolean)
      .join(' ');
  %>
  <body class="<%= bodyClass %>" data-event-room="<%= activeEvent ? activeEvent.id : (typeof portalEventRoom !== 'undefined' ? portalEventRoom : '') %>">
    <% if (currentUser) { %>
      <div class="worldnic-app">
        <button type="button" class="worldnic-overlay" data-mobile-sidebar-overlay aria-label="<%= t('nav.menu') %>"></button>

        <aside class="worldnic-sidebar" data-mobile-sidebar>
          <div class="worldnic-sidebar__brand">
            <a href="/dashboard" class="worldnic-brand">
              <span class="worldnic-brand__badge">
                <img src="/public/design-assets/brand/logo.png" alt="<%= t('app.name') %>" />
              </span>
              <span class="worldnic-brand__copy">
                <strong><%= t('app.name') %></strong>
                <small><%= t('app.tagline') %></small>
              </span>
            </a>

            <button type="button" class="worldnic-close" data-mobile-sidebar-close aria-label="<%= t('nav.menu') %>">&times;</button>
          </div>

          <% if (hasEvent) { %>
            <section class="worldnic-sidebar__workspace">
              <p class="worldnic-workspace__eyebrow"><%= t('nav.eventWorkspace') %></p>
              <h2 class="worldnic-workspace__title"><%= activeEvent.name %></h2>
              <div class="worldnic-workspace__meta">
                <span>
                  <img src="/public/design-assets/icons/feather/calendar.svg" alt="" />
                  <%= helpers.formatDate(activeEvent.start_date) %> - <%= helpers.formatDate(activeEvent.end_date) %>
                </span>
                <span>
                  <img src="/public/design-assets/icons/feather/layers.svg" alt="" />
                  <%= activeEvent.location %>
                </span>
              </div>
              <span class="status-<%= activeEvent.status %>"><%= helpers.statusLabel(activeEvent.status) %></span>
            </section>
          <% } %>

          <nav class="worldnic-nav">
            <% sidebarLinks.forEach((link) => { %>
              <a href="<%= link.href %>" class="worldnic-nav__link <%= link.active ? 'is-active' : '' %>">
                <span class="worldnic-nav__icon">
                  <img src="/public/design-assets/icons/feather/<%= link.icon %>.svg" alt="" />
                </span>
                <span><%= link.label %></span>
              </a>
            <% }) %>
          </nav>

          <div class="worldnic-sidebar__footer">
            <div class="worldnic-sidebar__hint">
              <strong><%= hasEvent ? t('event.quickActions') : t('dashboard.overview') %></strong>
              <p><%= hasEvent ? t('event.recentActivityDescription') : t('dashboard.description') %></p>
            </div>

            <form action="/logout" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn-secondary worldnic-sidebar__logout">
                <img src="/public/design-assets/icons/feather/log-out.svg" alt="" class="h-4 w-4 opacity-70" />
                <span><%= t('nav.logout') %></span>
              </button>
            </form>
          </div>
        </aside>

        <div class="worldnic-main">
          <header class="worldnic-header">
            <div class="worldnic-header__inner">
              <div class="worldnic-header__left">
                <button type="button" class="worldnic-menu-btn" data-mobile-sidebar-toggle aria-label="<%= t('nav.menu') %>">
                  <span></span>
                  <span></span>
                  <span></span>
                </button>

                <div class="worldnic-search">
                  <img src="/public/design-assets/icons/feather/search.svg" alt="" />
                  <span><%= t('nav.search') %></span>
                </div>
              </div>

              <div class="worldnic-header__actions">
                <div class="worldnic-locale">
                  <% supportedLocales.forEach((languageCode) => { %>
                    <a href="<%= localeHref(languageCode) %>" class="<%= locale === languageCode ? 'is-active' : '' %>">
                      <%= languageCode.toUpperCase() %>
                    </a>
                  <% }) %>
                </div>

                <a href="/events/new" class="btn-primary worldnic-create-btn">
                  <img src="/public/design-assets/icons/feather/plus.svg" alt="" class="h-4 w-4 brightness-0 invert" />
                  <span><%= t('nav.newEvent') %></span>
                </a>

                <div class="worldnic-user">
                  <div class="worldnic-user__avatar"><%= userInitials %></div>
                  <div class="worldnic-user__meta">
                    <strong><%= currentUser.full_name %></strong>
                    <small><%= currentUser.email %></small>
                  </div>
                </div>
              </div>
            </div>
          </header>

          <main class="worldnic-content">
            <% if (hasEvent) { %>
              <section class="worldnic-event-banner">
                <div class="worldnic-event-banner__header">
                  <div>
                    <p class="worldnic-eyebrow"><%= t('nav.eventWorkspace') %></p>
                    <h1 class="worldnic-event-banner__title"><%= activeEvent.name %></h1>

                    <div class="worldnic-meta">
                      <span class="worldnic-meta__item">
                        <img src="/public/design-assets/icons/feather/calendar.svg" alt="" />
                        <%= helpers.formatDate(activeEvent.start_date) %> - <%= helpers.formatDate(activeEvent.end_date) %>
                      </span>
                      <span class="worldnic-meta__item">
                        <img src="/public/design-assets/icons/feather/layers.svg" alt="" />
                        <%= activeEvent.location %>
                      </span>
                    </div>
                  </div>

                  <div class="worldnic-event-banner__actions">
                    <span class="status-<%= activeEvent.status %>"><%= helpers.statusLabel(activeEvent.status) %></span>
                    <a href="/events/<%= activeEvent.id %>/edit" class="btn-primary">
                      <img src="/public/design-assets/icons/feather/edit-3.svg" alt="" class="h-4 w-4 brightness-0 invert" />
                      <span><%= t('event.editSettings') %></span>
                    </a>
                  </div>
                </div>

                <div class="worldnic-event-banner__tabs">
                  <a href="/events/<%= activeEvent.id %>" class="event-tab <%= eventSection === 'overview' ? 'event-tab-active' : '' %>">
                    <img src="/public/design-assets/icons/feather/layers.svg" alt="" class="h-4 w-4 opacity-70" />
                    <span><%= t('event.sidebar.overview') %></span>
                  </a>
                  <a href="/events/<%= activeEvent.id %>/wristbands" class="event-tab <%= eventSection === 'wristbands' ? 'event-tab-active' : '' %>">
                    <img src="/public/design-assets/icons/feather/tag.svg" alt="" class="h-4 w-4 opacity-70" />
                    <span><%= t('event.sidebar.eventWristbands') %></span>
                  </a>
                  <a href="/events/<%= activeEvent.id %>/passes" class="event-tab <%= eventSection === 'passes' ? 'event-tab-active' : '' %>">
                    <img src="/public/design-assets/icons/feather/layers.svg" alt="" class="h-4 w-4 opacity-70" />
                    <span><%= t('event.sidebar.autoPasses') %></span>
                  </a>
                  <a href="/events/<%= activeEvent.id %>/request-profiles" class="event-tab <%= eventSection === 'profiles' ? 'event-tab-active' : '' %>">
                    <img src="/public/design-assets/icons/feather/users.svg" alt="" class="h-4 w-4 opacity-70" />
                    <span><%= t('event.sidebar.requestProfiles') %></span>
                  </a>
                  <a href="/events/<%= activeEvent.id %>/edit" class="event-tab <%= eventSection === 'settings' ? 'event-tab-active' : '' %>">
                    <img src="/public/design-assets/icons/feather/activity.svg" alt="" class="h-4 w-4 opacity-70" />
                    <span><%= t('event.sidebar.settings') %></span>
                  </a>
                </div>

                <% if (eventSection === 'settings') { %>
                  <div class="worldnic-event-subtabs">
                    <a href="/events/<%= activeEvent.id %>/edit" class="event-subtab <%= currentPath.includes('/edit') ? 'event-subtab-active' : '' %>"><%= t('event.settings.edit') %></a>
                    <a href="/events/<%= activeEvent.id %>/members" class="event-subtab <%= currentPath.includes('/members') ? 'event-subtab-active' : '' %>"><%= t('event.settings.members') %></a>
                    <a href="/events/<%= activeEvent.id %>/activity" class="event-subtab <%= currentPath.includes('/activity') ? 'event-subtab-active' : '' %>"><%= t('event.settings.activity') %></a>
                  </div>
                <% } %>

                <% if (eventSection === 'profiles') { %>
                  <div class="worldnic-event-subtabs">
                    <a href="#profile-list" class="event-subtab"><%= t('requestProfiles.nav.list') %></a>
                    <a href="#profile-create" class="event-subtab"><%= t('requestProfiles.nav.create') %></a>
                  </div>
                <% } %>
              </section>
            <% } %>

            <%- include('partials/flash') %>
            <%- body %>
          </main>
        </div>
      </div>
    <% } else if (isAuthPage) { %>
      <%- body %>
    <% } else { %>
      <div class="worldnic-guest-shell <%= isPublicPortal && portalPageMode === 'manage' ? 'worldnic-guest-shell-portal' : '' %>">
        <header class="worldnic-guest-topbar">
          <a href="<%= isPublicPortal ? '/p' : '/login' %>" class="worldnic-brand">
            <span class="worldnic-brand__badge">
              <img src="/public/design-assets/brand/logo.png" alt="<%= t('app.name') %>" />
            </span>
            <span class="worldnic-brand__copy">
              <strong><%= t('app.name') %></strong>
              <small><%= t('app.tagline') %></small>
            </span>
          </a>

          <div class="worldnic-guest-actions">
            <div class="worldnic-locale">
              <% supportedLocales.forEach((languageCode) => { %>
                <a href="<%= localeHref(languageCode) %>" class="<%= locale === languageCode ? 'is-active' : '' %>">
                  <%= languageCode.toUpperCase() %>
                </a>
              <% }) %>
            </div>
            <% if (!isPublicPortal) { %>
              <a href="/login" class="btn-secondary"><%= t('buttons.login') %></a>
              <a href="/register" class="btn-primary"><%= t('buttons.createAccount') %></a>
            <% } %>
          </div>
        </header>

        <main class="worldnic-guest-main">
          <%- include('partials/flash') %>
          <%- body %>
        </main>
      </div>
    <% } %>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/public/js/app.js"></script>
  </body>
</html>
