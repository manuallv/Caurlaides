<section class="space-y-6">
  <section class="shell-card request-profile-editor request-profile-editor--compact">
    <div class="request-profile-editor__head">
      <div>
        <p class="request-profile-editor__eyebrow"><%= t('system.eyebrow') %></p>
        <h1 class="request-profile-editor__title"><%= t('system.settings.templatesTitle') %></h1>
        <p class="request-profile-editor__description"><%= t('system.settings.templatesDescription') %></p>
      </div>
    </div>

    <form action="/system/settings/templates" method="POST" class="request-profile-editor__form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="request-profile-editor__quotas">
        <section class="request-profile-quota-card panel">
          <div class="request-profile-quota-card__head"><h2><%= t('system.settings.forgotTemplate') %></h2></div>
          <div class="request-profile-quota-list">
            <label>
              <span class="field-label"><%= t('system.settings.subject') %></span>
              <input name="forgotPasswordSubject" type="text" class="field-input" value="<%= templates.forgot_password.subject %>" />
            </label>
            <label>
              <span class="field-label">HTML</span>
              <textarea name="forgotPasswordHtml" rows="8" class="field-input"><%= templates.forgot_password.html_content %></textarea>
            </label>
            <label>
              <span class="field-label">Text</span>
              <textarea name="forgotPasswordText" rows="5" class="field-input"><%= templates.forgot_password.text_content || '' %></textarea>
            </label>
          </div>
        </section>

        <section class="request-profile-quota-card panel">
          <div class="request-profile-quota-card__head"><h2><%= t('system.settings.inviteTemplate') %></h2></div>
          <div class="request-profile-quota-list">
            <label>
              <span class="field-label"><%= t('system.settings.subject') %></span>
              <input name="portalInviteSubject" type="text" class="field-input" value="<%= templates.portal_invite.subject %>" />
            </label>
            <label>
              <span class="field-label">HTML</span>
              <textarea name="portalInviteHtml" rows="8" class="field-input"><%= templates.portal_invite.html_content %></textarea>
            </label>
            <label>
              <span class="field-label">Text</span>
              <textarea name="portalInviteText" rows="5" class="field-input"><%= templates.portal_invite.text_content || '' %></textarea>
            </label>
          </div>
        </section>
      </div>

      <div class="request-profile-editor__actions">
        <span class="system-settings-help"><%= t('system.settings.description') %></span>
        <button type="submit" class="btn-primary"><%= t('buttons.save') %></button>
      </div>
    </form>
  </section>
</section>
