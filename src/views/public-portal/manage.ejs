<section class="space-y-6">
  <div class="shell-card overflow-hidden">
    <div class="flex flex-col gap-4 border-b border-slate-200/80 px-5 py-5 sm:px-6 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="worldnic-eyebrow"><%= t('portal.eyebrow') %></p>
        <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900"><%= profile.name %></h1>
        <p class="mt-2 text-sm text-slate-500"><%= t('portal.manage.description') %></p>
      </div>

      <form action="/portal/<%= profile.public_slug %>/logout" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="btn-secondary"><%= t('portal.logout') %></button>
      </form>
    </div>

    <div class="grid gap-4 px-5 py-5 sm:px-6 lg:grid-cols-2">
      <div class="panel">
        <h2 class="text-lg font-bold text-slate-900"><%= t('nav.passes') %></h2>
        <div class="mt-4 flex flex-wrap gap-2">
          <% if (!passQuotaUsage.length) { %>
            <p class="text-sm text-slate-500"><%= t('portal.noPassQuota') %></p>
          <% } %>
          <% passQuotaUsage.forEach((quota) => { %>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= quota.category_name %>: <%= quota.used_count %>/<%= quota.quota %> · <%= t('requestProfiles.remaining', { count: quota.remaining_count }) %></span>
          <% }) %>
        </div>
      </div>

      <div class="panel">
        <h2 class="text-lg font-bold text-slate-900"><%= t('nav.wristbands') %></h2>
        <div class="mt-4 flex flex-wrap gap-2">
          <% if (!wristbandQuotaUsage.length) { %>
            <p class="text-sm text-slate-500"><%= t('portal.noWristbandQuota') %></p>
          <% } %>
          <% wristbandQuotaUsage.forEach((quota) => { %>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= quota.category_name %>: <%= quota.used_count %>/<%= quota.quota %> · <%= t('requestProfiles.remaining', { count: quota.remaining_count }) %></span>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <div class="shell-card overflow-hidden">
      <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
        <h2 class="text-xl font-bold text-slate-900"><%= t('portal.createPassRequest') %></h2>
      </div>
      <% if (!passPortalOpen) { %>
        <div class="px-5 py-5 sm:px-6">
          <p class="text-sm text-slate-500"><%= t('portal.deadlinePassed') %></p>
        </div>
      <% } else if (!passQuotaUsage.length) { %>
        <div class="px-5 py-5 sm:px-6">
          <p class="text-sm text-slate-500"><%= t('portal.noPassQuota') %></p>
        </div>
      <% } else if (!canCreatePassRequests) { %>
        <div class="px-5 py-5 sm:px-6">
          <p class="text-sm text-slate-500"><%= t('portal.noAvailableTypes') %></p>
        </div>
      <% } else { %>
        <form action="/portal/<%= profile.public_slug %>/pass" method="POST" class="space-y-4 px-5 py-5 sm:px-6">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div>
            <label class="field-label"><%= t('access.fields.type') %></label>
            <select name="categoryId" class="field-input" required>
              <option value=""><%= t('portal.selectType') %></option>
              <% passQuotaUsage.filter((quota) => quota.remaining_count > 0).forEach((quota) => { %>
                <option value="<%= quota.category_id %>"><%= quota.category_name %> (<%= quota.used_count %>/<%= quota.quota %>)</option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="field-label"><%= t('portal.fields.fullName') %></label>
            <input name="fullName" type="text" class="field-input" required />
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="field-label"><%= t('portal.fields.phone') %></label>
              <input name="phone" type="text" class="field-input" required />
            </div>
            <div>
              <label class="field-label"><%= t('field.email') %></label>
              <input name="email" type="email" class="field-input" />
            </div>
          </div>
          <div>
            <label class="field-label"><%= t('portal.fields.company') %></label>
            <input name="companyName" type="text" class="field-input" value="<%= profile.name %>" required />
          </div>
          <div>
            <label class="field-label"><%= t('portal.fields.notes') %></label>
            <textarea name="notes" rows="3" class="field-input"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full"><%= t('portal.addRequest') %></button>
        </form>
      <% } %>
    </div>

    <div class="shell-card overflow-hidden">
      <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
        <h2 class="text-xl font-bold text-slate-900"><%= t('portal.createWristbandRequest') %></h2>
      </div>
      <% if (!wristbandPortalOpen) { %>
        <div class="px-5 py-5 sm:px-6">
          <p class="text-sm text-slate-500"><%= t('portal.deadlinePassed') %></p>
        </div>
      <% } else if (!wristbandQuotaUsage.length) { %>
        <div class="px-5 py-5 sm:px-6">
          <p class="text-sm text-slate-500"><%= t('portal.noWristbandQuota') %></p>
        </div>
      <% } else if (!canCreateWristbandRequests) { %>
        <div class="px-5 py-5 sm:px-6">
          <p class="text-sm text-slate-500"><%= t('portal.noAvailableTypes') %></p>
        </div>
      <% } else { %>
        <form action="/portal/<%= profile.public_slug %>/wristband" method="POST" class="space-y-4 px-5 py-5 sm:px-6">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div>
            <label class="field-label"><%= t('access.fields.type') %></label>
            <select name="categoryId" class="field-input" required>
              <option value=""><%= t('portal.selectType') %></option>
              <% wristbandQuotaUsage.filter((quota) => quota.remaining_count > 0).forEach((quota) => { %>
                <option value="<%= quota.category_id %>"><%= quota.category_name %> (<%= quota.used_count %>/<%= quota.quota %>)</option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="field-label"><%= t('portal.fields.fullName') %></label>
            <input name="fullName" type="text" class="field-input" required />
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="field-label"><%= t('portal.fields.phone') %></label>
              <input name="phone" type="text" class="field-input" required />
            </div>
            <div>
              <label class="field-label"><%= t('field.email') %></label>
              <input name="email" type="email" class="field-input" />
            </div>
          </div>
          <div>
            <label class="field-label"><%= t('portal.fields.company') %></label>
            <input name="companyName" type="text" class="field-input" value="<%= profile.name %>" required />
          </div>
          <div>
            <label class="field-label"><%= t('portal.fields.notes') %></label>
            <textarea name="notes" rows="3" class="field-input"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full"><%= t('portal.addRequest') %></button>
        </form>
      <% } %>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <div class="shell-card overflow-hidden">
      <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
        <h2 class="text-xl font-bold text-slate-900"><%= t('nav.passes') %></h2>
      </div>
      <div class="space-y-4 px-5 py-5 sm:px-6">
        <% if (!passRequests.length) { %>
          <p class="text-sm text-slate-500"><%= t('portal.noPassRequests') %></p>
        <% } %>
        <% passRequests.forEach((request) => { %>
          <article class="rounded-2xl border border-slate-200 p-4">
            <div class="flex flex-wrap items-center gap-2">
              <p class="text-sm font-bold text-slate-900"><%= request.full_name %></p>
              <span class="status-<%= request.status === 'handed_out' ? 'active' : 'pending' %>"><%= t(`statuses.${request.status}`) %></span>
            </div>
            <p class="mt-2 text-sm text-slate-500"><%= request.category_name %> · <%= request.company_name || t('common.notSet') %></p>
            <% if (request.isEditable) { %>
              <form action="/portal/<%= profile.public_slug %>/pass/<%= request.id %>?_method=PUT" method="POST" class="mt-4 grid gap-3">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <select name="categoryId" class="field-input" required>
                  <% passQuotaUsage.forEach((quota) => { %>
                    <option value="<%= quota.category_id %>" <%= Number(quota.category_id) === Number(request.category_id) ? 'selected' : '' %>><%= quota.category_name %> (<%= quota.used_count %>/<%= quota.quota %>)</option>
                  <% }) %>
                </select>
                <input name="fullName" type="text" class="field-input" value="<%= request.full_name %>" required />
                <input name="companyName" type="text" class="field-input" value="<%= request.company_name || profile.name %>" required />
                <div class="grid gap-3 md:grid-cols-2">
                  <input name="phone" type="text" class="field-input" value="<%= request.phone || '' %>" placeholder="<%= t('portal.fields.phone') %>" required />
                  <input name="email" type="email" class="field-input" value="<%= request.email || '' %>" placeholder="<%= t('field.email') %>" />
                </div>
                <textarea name="notes" rows="3" class="field-input"><%= request.notes || '' %></textarea>
                <div class="flex gap-2">
                  <button type="submit" class="btn-secondary w-full"><%= t('portal.saveRequest') %></button>
                  <button formaction="/portal/<%= profile.public_slug %>/pass/<%= request.id %>?_method=DELETE" formmethod="POST" class="btn-danger w-full"><%= t('portal.deleteRequest') %></button>
                </div>
              </form>
            <% } else { %>
              <p class="mt-3 text-sm text-slate-500"><%= t('portal.requestLocked') %></p>
            <% } %>
          </article>
        <% }) %>
      </div>
    </div>

    <div class="shell-card overflow-hidden">
      <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
        <h2 class="text-xl font-bold text-slate-900"><%= t('nav.wristbands') %></h2>
      </div>
      <div class="space-y-4 px-5 py-5 sm:px-6">
        <% if (!wristbandRequests.length) { %>
          <p class="text-sm text-slate-500"><%= t('portal.noWristbandRequests') %></p>
        <% } %>
        <% wristbandRequests.forEach((request) => { %>
          <article class="rounded-2xl border border-slate-200 p-4">
            <div class="flex flex-wrap items-center gap-2">
              <p class="text-sm font-bold text-slate-900"><%= request.full_name %></p>
              <span class="status-<%= request.status === 'handed_out' ? 'active' : 'pending' %>"><%= t(`statuses.${request.status}`) %></span>
            </div>
            <p class="mt-2 text-sm text-slate-500"><%= request.category_name %> · <%= request.company_name || t('common.notSet') %></p>
            <% if (request.isEditable) { %>
              <form action="/portal/<%= profile.public_slug %>/wristband/<%= request.id %>?_method=PUT" method="POST" class="mt-4 grid gap-3">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <select name="categoryId" class="field-input" required>
                  <% wristbandQuotaUsage.forEach((quota) => { %>
                    <option value="<%= quota.category_id %>" <%= Number(quota.category_id) === Number(request.category_id) ? 'selected' : '' %>><%= quota.category_name %> (<%= quota.used_count %>/<%= quota.quota %>)</option>
                  <% }) %>
                </select>
                <input name="fullName" type="text" class="field-input" value="<%= request.full_name %>" required />
                <input name="companyName" type="text" class="field-input" value="<%= request.company_name || profile.name %>" required />
                <div class="grid gap-3 md:grid-cols-2">
                  <input name="phone" type="text" class="field-input" value="<%= request.phone || '' %>" placeholder="<%= t('portal.fields.phone') %>" required />
                  <input name="email" type="email" class="field-input" value="<%= request.email || '' %>" placeholder="<%= t('field.email') %>" />
                </div>
                <textarea name="notes" rows="3" class="field-input"><%= request.notes || '' %></textarea>
                <div class="flex gap-2">
                  <button type="submit" class="btn-secondary w-full"><%= t('portal.saveRequest') %></button>
                  <button formaction="/portal/<%= profile.public_slug %>/wristband/<%= request.id %>?_method=DELETE" formmethod="POST" class="btn-danger w-full"><%= t('portal.deleteRequest') %></button>
                </div>
              </form>
            <% } else { %>
              <p class="mt-3 text-sm text-slate-500"><%= t('portal.requestLocked') %></p>
            <% } %>
          </article>
        <% }) %>
      </div>
    </div>
  </div>
</section>
