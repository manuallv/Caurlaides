<section class="space-y-6">
  <% if (canManage) { %>
    <div class="grid gap-6 xl:grid-cols-2">
      <div class="shell-card overflow-hidden">
        <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
          <h1 class="text-xl font-bold text-slate-900"><%= t('categories.createPass') %></h1>
        </div>
        <form action="/events/<%= activeEvent.id %>/categories" method="POST" class="space-y-4 px-5 py-5 sm:px-6">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="type" value="pass" />
          <div>
            <label class="field-label" for="pass-name"><%= t('categories.name') %></label>
            <input id="pass-name" name="name" type="text" class="field-input" required />
          </div>
          <div>
            <label class="field-label" for="pass-description"><%= t('categories.description') %></label>
            <textarea id="pass-description" name="description" rows="3" class="field-input"></textarea>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="field-label" for="pass-quota"><%= t('categories.quota') %></label>
              <input id="pass-quota" name="quota" type="number" min="1" class="field-input" />
            </div>
            <div>
              <label class="field-label" for="pass-sort-order"><%= t('categories.sortOrder') %></label>
              <input id="pass-sort-order" name="sortOrder" type="number" min="0" class="field-input" value="0" />
            </div>
          </div>
          <label class="flex items-center gap-3 rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700">
            <input type="checkbox" name="isActive" checked />
            <%= t('categories.active') %>
          </label>
          <button type="submit" class="btn-primary w-full"><%= t('categories.addPass') %></button>
        </form>
      </div>

      <div class="shell-card overflow-hidden">
        <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
          <h2 class="text-xl font-bold text-slate-900"><%= t('categories.createWristband') %></h2>
        </div>
        <form action="/events/<%= activeEvent.id %>/categories" method="POST" class="space-y-4 px-5 py-5 sm:px-6">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="type" value="wristband" />
          <div>
            <label class="field-label" for="wristband-name"><%= t('categories.name') %></label>
            <input id="wristband-name" name="name" type="text" class="field-input" required />
          </div>
          <div>
            <label class="field-label" for="wristband-description"><%= t('categories.description') %></label>
            <textarea id="wristband-description" name="description" rows="3" class="field-input"></textarea>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="field-label" for="wristband-quota"><%= t('categories.quota') %></label>
              <input id="wristband-quota" name="quota" type="number" min="1" class="field-input" />
            </div>
            <div>
              <label class="field-label" for="wristband-sort-order"><%= t('categories.sortOrder') %></label>
              <input id="wristband-sort-order" name="sortOrder" type="number" min="0" class="field-input" value="0" />
            </div>
          </div>
          <label class="flex items-center gap-3 rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700">
            <input type="checkbox" name="isActive" checked />
            <%= t('categories.active') %>
          </label>
          <button type="submit" class="btn-primary w-full"><%= t('categories.addWristband') %></button>
        </form>
      </div>
    </div>
  <% } %>

  <div class="grid gap-6 xl:grid-cols-2">
    <div class="shell-card overflow-hidden">
      <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
        <h2 class="text-xl font-bold text-slate-900"><%= t('categories.passTitle') %></h2>
      </div>
      <div class="space-y-4 px-5 py-5 sm:px-6">
        <% if (!passCategories.length) { %>
          <p class="text-sm text-slate-500"><%= t('categories.nonePass') %></p>
        <% } %>
        <% passCategories.forEach((category) => { %>
          <form action="/events/<%= activeEvent.id %>/categories/pass/<%= category.id %>?_method=PUT" method="POST" class="rounded-2xl border border-slate-200 p-4">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="type" value="pass" />
            <div class="grid gap-4">
              <div class="grid gap-4 md:grid-cols-2">
                <div>
                  <label class="field-label"><%= t('categories.name') %></label>
                  <input name="name" type="text" class="field-input" value="<%= category.name %>" <%= canManage ? '' : 'disabled' %> />
                </div>
                <div>
                  <label class="field-label"><%= t('categories.quota') %></label>
                  <input name="quota" type="number" min="1" class="field-input" value="<%= category.quota || '' %>" <%= canManage ? '' : 'disabled' %> />
                </div>
              </div>
              <div>
                <label class="field-label"><%= t('categories.description') %></label>
                <textarea name="description" rows="3" class="field-input" <%= canManage ? '' : 'disabled' %>><%= category.description || '' %></textarea>
              </div>
              <div class="grid gap-4 md:grid-cols-2">
                <div>
                  <label class="field-label"><%= t('categories.sortOrder') %></label>
                  <input name="sortOrder" type="number" min="0" class="field-input" value="<%= category.sort_order %>" <%= canManage ? '' : 'disabled' %> />
                </div>
                <label class="flex items-center gap-3 rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700">
                  <input type="checkbox" name="isActive" <%= category.is_active ? 'checked' : '' %> <%= canManage ? '' : 'disabled' %> />
                  <%= t('categories.active') %>
                </label>
              </div>
              <% if (canManage) { %>
                <div class="flex flex-wrap gap-3">
                  <button type="submit" class="btn-secondary"><%= t('categories.save') %></button>
                  <button formaction="/events/<%= activeEvent.id %>/categories/pass/<%= category.id %>?_method=DELETE" formmethod="POST" class="btn-danger"><%= t('categories.delete') %></button>
                </div>
              <% } %>
            </div>
          </form>
        <% }) %>
      </div>
    </div>

    <div class="shell-card overflow-hidden">
      <div class="border-b border-slate-200/80 px-5 py-5 sm:px-6">
        <h2 class="text-xl font-bold text-slate-900"><%= t('categories.wristbandTitle') %></h2>
      </div>
      <div class="space-y-4 px-5 py-5 sm:px-6">
        <% if (!wristbandCategories.length) { %>
          <p class="text-sm text-slate-500"><%= t('categories.noneWristband') %></p>
        <% } %>
        <% wristbandCategories.forEach((category) => { %>
          <form action="/events/<%= activeEvent.id %>/categories/wristband/<%= category.id %>?_method=PUT" method="POST" class="rounded-2xl border border-slate-200 p-4">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="type" value="wristband" />
            <div class="grid gap-4">
              <div class="grid gap-4 md:grid-cols-2">
                <div>
                  <label class="field-label"><%= t('categories.name') %></label>
                  <input name="name" type="text" class="field-input" value="<%= category.name %>" <%= canManage ? '' : 'disabled' %> />
                </div>
                <div>
                  <label class="field-label"><%= t('categories.quota') %></label>
                  <input name="quota" type="number" min="1" class="field-input" value="<%= category.quota || '' %>" <%= canManage ? '' : 'disabled' %> />
                </div>
              </div>
              <div>
                <label class="field-label"><%= t('categories.description') %></label>
                <textarea name="description" rows="3" class="field-input" <%= canManage ? '' : 'disabled' %>><%= category.description || '' %></textarea>
              </div>
              <div class="grid gap-4 md:grid-cols-2">
                <div>
                  <label class="field-label"><%= t('categories.sortOrder') %></label>
                  <input name="sortOrder" type="number" min="0" class="field-input" value="<%= category.sort_order %>" <%= canManage ? '' : 'disabled' %> />
                </div>
                <label class="flex items-center gap-3 rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700">
                  <input type="checkbox" name="isActive" <%= category.is_active ? 'checked' : '' %> <%= canManage ? '' : 'disabled' %> />
                  <%= t('categories.active') %>
                </label>
              </div>
              <% if (canManage) { %>
                <div class="flex flex-wrap gap-3">
                  <button type="submit" class="btn-secondary"><%= t('categories.save') %></button>
                  <button formaction="/events/<%= activeEvent.id %>/categories/wristband/<%= category.id %>?_method=DELETE" formmethod="POST" class="btn-danger"><%= t('categories.delete') %></button>
                </div>
              <% } %>
            </div>
          </form>
        <% }) %>
      </div>
    </div>
  </div>
</section>
