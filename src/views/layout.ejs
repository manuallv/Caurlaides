<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle ? `${pageTitle} | Caurlaides` : 'Caurlaides' %></title>
    <link rel="stylesheet" href="/public/css/app.css" />
  </head>
  <body data-event-room="<%= activeEvent ? activeEvent.id : '' %>">
    <% 
      const hasEvent = Boolean(activeEvent);
      const userInitials = currentUser
        ? currentUser.full_name
            .split(' ')
            .filter(Boolean)
            .slice(0, 2)
            .map((part) => part[0].toUpperCase())
            .join('')
        : '';

      const sidebarLinks = [
        {
          href: '/dashboard',
          label: 'Dashboard',
          icon: 'grid',
          active: currentPath === '/' || currentPath.startsWith('/dashboard'),
        },
        {
          href: '/events/new',
          label: 'Create',
          icon: 'plus',
          active: currentPath.startsWith('/events/new'),
        },
      ];

      if (hasEvent) {
        sidebarLinks.push(
          {
            href: `/events/${activeEvent.id}`,
            label: 'Event',
            icon: 'layers',
            active: currentPath === `/events/${activeEvent.id}`,
          },
          {
            href: `/events/${activeEvent.id}/categories`,
            label: 'Categories',
            icon: 'tag',
            active: currentPath.includes('/categories'),
          },
          {
            href: `/events/${activeEvent.id}/members`,
            label: 'Team',
            icon: 'users',
            active: currentPath.includes('/members'),
          },
          {
            href: `/events/${activeEvent.id}/activity`,
            label: 'Activity',
            icon: 'activity',
            active: currentPath.includes('/activity'),
          },
        );
      }
    %>

    <% if (currentUser) { %>
      <div class="min-h-screen lg:flex">
        <aside class="hidden w-[96px] flex-col items-center justify-between border-r border-slate-200/80 bg-white px-3 py-4 lg:flex">
          <div class="flex w-full flex-col items-center gap-6">
            <a
              href="/dashboard"
              class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-b from-cyan-400 to-blue-600 text-lg font-extrabold text-white shadow-lg shadow-blue-500/20"
            >
              C
            </a>

            <nav class="flex w-full flex-col gap-2">
              <% sidebarLinks.forEach((link) => { %>
                <a href="<%= link.href %>" class="rail-link <%= link.active ? 'rail-link-active' : '' %>">
                  <span class="rail-icon">
                    <img
                      src="/public/design-assets/icons/feather/<%= link.icon %>.svg"
                      alt=""
                      class="h-4 w-4 opacity-70"
                    />
                  </span>
                  <span><%= link.label %></span>
                </a>
              <% }) %>
            </nav>
          </div>

          <form action="/logout" method="POST" class="w-full">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="rail-link w-full">
              <span class="rail-icon">
                <img src="/public/design-assets/icons/feather/log-out.svg" alt="" class="h-4 w-4 opacity-70" />
              </span>
              <span>Logout</span>
            </button>
          </form>
        </aside>

        <div class="flex min-h-screen flex-1 flex-col">
          <header class="sticky top-0 z-30 border-b border-slate-200/80 bg-white/95 backdrop-blur">
            <div class="px-4 py-3 sm:px-6 lg:px-8">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                  <button type="button" class="btn-secondary lg:hidden" data-mobile-menu-toggle>
                    Menu
                  </button>

                  <div class="top-search hidden min-w-[280px] sm:flex">
                    <img src="/public/design-assets/icons/feather/search.svg" alt="" class="h-4 w-4 opacity-60" />
                    <span>Search anything</span>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="hidden items-center rounded-xl border border-slate-200 bg-white p-1 sm:flex">
                    <span class="toolbar-chip toolbar-chip-active">Light</span>
                    <span class="toolbar-chip">Dark</span>
                  </div>

                  <a href="/events/new" class="btn-primary hidden sm:inline-flex">
                    <img src="/public/design-assets/icons/feather/plus.svg" alt="" class="h-4 w-4 brightness-0 invert" />
                    <span>New event</span>
                  </a>

                  <div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-2.5 py-2">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-b from-cyan-400 to-blue-600 text-sm font-bold text-white">
                      <%= userInitials %>
                    </div>
                    <div class="hidden sm:block">
                      <p class="text-sm font-semibold text-slate-900"><%= currentUser.full_name %></p>
                      <p class="text-xs text-slate-500"><%= currentUser.email %></p>
                    </div>
                  </div>
                </div>
              </div>

              <div data-mobile-menu class="mt-3 hidden rounded-2xl border border-slate-200 bg-white p-3 lg:hidden">
                <div class="flex flex-col gap-2">
                  <% sidebarLinks.forEach((link) => { %>
                    <a href="<%= link.href %>" class="btn-secondary justify-start">
                      <img src="/public/design-assets/icons/feather/<%= link.icon %>.svg" alt="" class="h-4 w-4 opacity-70" />
                      <span><%= link.label %></span>
                    </a>
                  <% }) %>

                  <form action="/logout" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="btn-secondary w-full justify-start">
                      <img src="/public/design-assets/icons/feather/log-out.svg" alt="" class="h-4 w-4 opacity-70" />
                      <span>Logout</span>
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </header>

          <main class="flex-1 px-4 py-4 sm:px-6 lg:px-8">
            <% if (hasEvent) { %>
              <section class="shell-card mb-4 overflow-hidden">
                <div class="flex flex-col gap-4 border-b border-slate-200/80 px-5 py-5 sm:px-6 lg:flex-row lg:items-center lg:justify-between">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Event workspace</p>
                    <h1 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900"><%= activeEvent.name %></h1>
                    <p class="mt-2 text-sm text-slate-500">
                      <%= activeEvent.location %> · <%= helpers.formatDate(activeEvent.start_date) %> to <%= helpers.formatDate(activeEvent.end_date) %>
                    </p>
                  </div>

                  <div class="flex flex-wrap items-center gap-2">
                    <span class="status-<%= activeEvent.status %>"><%= activeEvent.status %></span>
                    <a href="/events/<%= activeEvent.id %>/edit" class="btn-primary">
                      <img src="/public/design-assets/icons/feather/edit-3.svg" alt="" class="h-4 w-4 brightness-0 invert" />
                      <span>Edit event</span>
                    </a>
                  </div>
                </div>

                <div class="flex flex-wrap gap-2 px-5 py-4 sm:px-6">
                  <a href="/events/<%= activeEvent.id %>" class="event-tab <%= currentPath === `/events/${activeEvent.id}` ? 'event-tab-active' : '' %>">
                    <img src="/public/design-assets/icons/feather/layers.svg" alt="" class="h-4 w-4 opacity-70" />
                    <span>Overview</span>
                  </a>
                  <a href="/events/<%= activeEvent.id %>/categories" class="event-tab <%= currentPath.includes('/categories') ? 'event-tab-active' : '' %>">
                    <img src="/public/design-assets/icons/feather/tag.svg" alt="" class="h-4 w-4 opacity-70" />
                    <span>Categories</span>
                  </a>
                  <a href="/events/<%= activeEvent.id %>/members" class="event-tab <%= currentPath.includes('/members') ? 'event-tab-active' : '' %>">
                    <img src="/public/design-assets/icons/feather/users.svg" alt="" class="h-4 w-4 opacity-70" />
                    <span>Collaborators</span>
                  </a>
                  <a href="/events/<%= activeEvent.id %>/activity" class="event-tab <%= currentPath.includes('/activity') ? 'event-tab-active' : '' %>">
                    <img src="/public/design-assets/icons/feather/activity.svg" alt="" class="h-4 w-4 opacity-70" />
                    <span>Activity</span>
                  </a>
                </div>
              </section>
            <% } %>

            <%- include('partials/flash') %>
            <%- body %>
          </main>
        </div>
      </div>
    <% } else { %>
      <div class="mx-auto min-h-screen max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
        <header class="shell-card mb-4 overflow-hidden">
          <div class="flex items-center justify-between gap-4 px-5 py-4 sm:px-6">
            <div class="flex items-center gap-3">
              <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-b from-cyan-400 to-blue-600 text-lg font-extrabold text-white shadow-lg shadow-blue-500/20">
                C
              </div>
              <div>
                <p class="text-lg font-extrabold tracking-tight text-slate-900">Caurlaides</p>
                <p class="text-sm text-slate-500">Professional event access operations</p>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <a href="/login" class="btn-secondary">Log in</a>
              <a href="/register" class="btn-primary">Create account</a>
            </div>
          </div>
        </header>

        <%- include('partials/flash') %>
        <main>
          <%- body %>
        </main>
      </div>
    <% } %>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/public/js/app.js"></script>
  </body>
</html>
