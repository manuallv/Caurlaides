<%
  const localeHref = (code) => `/language/${code}?redirect=${encodeURIComponent(currentPath || '/')}`;
%>

<section class="authincation worldnic-auth-shell">
  <aside class="login-aside worldnic-auth-aside">
    <a href="/login" class="worldnic-auth-brand">
      <span class="worldnic-brand__badge">
        <img src="/public/design-assets/brand/logo.png" alt="<%= t('app.name') %>" />
      </span>
      <span class="worldnic-brand__copy">
        <strong><%= t('app.name') %></strong>
        <small><%= t('app.tagline') %></small>
      </span>
    </a>

    <div class="worldnic-auth-copy">
      <p class="worldnic-eyebrow"><%= t('auth.portal') %></p>
      <h1><%= t('auth.forgot.title') %></h1>
      <p><%= t('auth.forgot.description') %></p>
    </div>

    <div class="worldnic-auth-illustration aside-image" style="background-image: url('/public/design-assets/worldnic/pic1.svg')"></div>
  </aside>

  <div class="worldnic-auth-main">
    <div class="authincation-content style-2 worldnic-auth-card">
      <div class="worldnic-auth-topbar">
        <div>
          <p class="worldnic-eyebrow"><%= t('auth.portal') %></p>
          <h2 class="worldnic-auth-heading"><%= t('auth.forgot.title') %></h2>
        </div>

        <div class="worldnic-locale">
          <% supportedLocales.forEach((languageCode) => { %>
            <a href="<%= localeHref(languageCode) %>" class="<%= locale === languageCode ? 'is-active' : '' %>">
              <%= languageCode.toUpperCase() %>
            </a>
          <% }) %>
        </div>
      </div>

      <div class="auth-form worldnic-auth-form">
        <%- include('../partials/flash') %>

        <form action="/forgot-password" method="POST" class="space-y-4">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div>
            <label for="email" class="field-label"><%= t('field.email') %></label>
            <input id="email" name="email" type="email" class="field-input" autocomplete="email" required />
          </div>

          <button type="submit" class="btn-primary"><%= t('auth.forgot.submit') %></button>
        </form>

        <p class="worldnic-auth-footer">
          <a href="/login"><%= t('auth.forgot.backToLogin') %></a>
        </p>
      </div>
    </div>
  </div>
</section>
